"""Unit tests for lib.txt. Pure functions, no fixtures or containers."""

import sys
import unittest

sys.path.insert(0, '..')

import lib.txt as txt


class TestCompileRegex(unittest.TestCase):
    def test_single_pattern(self):
        ok, pattern = txt.compile_regex(r'^[a-z]+$')
        self.assertTrue(ok)
        self.assertIsNotNone(pattern.match('abc'))
        self.assertIsNone(pattern.match('ABC'))

    def test_list_of_patterns(self):
        result = txt.compile_regex([r'^[a-z]+$', r'\d+'])
        self.assertEqual(len(result), 2)
        self.assertTrue(all(ok for ok, _ in result))

    def test_invalid_pattern_returns_error(self):
        ok, msg = txt.compile_regex(r'[')
        self.assertFalse(ok)
        self.assertIn('errors', msg)


class TestExceptionToText(unittest.TestCase):
    def test_formats_type_and_message(self):
        self.assertEqual(txt.exception2text(ValueError('boom')), 'ValueError: boom')


class TestExtractStr(unittest.TestCase):
    def test_marker_not_found_is_empty(self):
        self.assertEqual(txt.extract_str('abcde', 'x', 'y'), '')

    def test_from_to_excluded_by_default(self):
        self.assertEqual(txt.extract_str('abcde', 'b', 'x'), 'cde')
        self.assertEqual(txt.extract_str('abcde', 'b', 'd'), 'c')

    def test_include_fromto(self):
        self.assertEqual(txt.extract_str('abcde', 'b', 'x', include_fromto=True), 'bcde')
        self.assertEqual(txt.extract_str('abcde', 'b', 'd', include_fromto=True), 'bcd')

    def test_be_tolerant_combinations(self):
        # to-marker missing: tolerant returns the rest, non-tolerant returns ''.
        self.assertEqual(txt.extract_str('abcde', 'b', 'x', be_tolerant=True), 'cde')
        self.assertEqual(txt.extract_str('abcde', 'b', 'x', be_tolerant=False), '')


class TestFilterMltext(unittest.TestCase):
    def setUp(self):
        self.s = 'Lorem ipsum\n\ndolor sit amet\n\nconsectetur adipisicing'

    def test_drops_paragraphs_matching_any_pattern(self):
        self.assertEqual(
            txt.filter_mltext(self.s, ['ipsum']),
            '\ndolor sit amet\n\nconsectetur adipisicing\n',
        )

    def test_substring_match(self):
        self.assertEqual(txt.filter_mltext(self.s, ['d']), 'Lorem ipsum\n\n\n')


class TestMatchRegex(unittest.TestCase):
    def test_match(self):
        ok, m = txt.match_regex(r'^abc$', 'abc')
        self.assertTrue(ok)
        self.assertIsNotNone(m)

    def test_no_match_is_none(self):
        ok, m = txt.match_regex(r'^abc$', 'xyz')
        self.assertTrue(ok)
        self.assertIsNone(m)

    def test_invalid_pattern(self):
        ok, msg = txt.match_regex(r'[', 'text', key='ex')
        self.assertFalse(ok)
        self.assertIn('ex', msg)


class TestMltext2Array(unittest.TestCase):
    def test_sorts_by_column(self):
        s = '1662130953 timedatex\n1662130757 python3-pip-wheel\n1662130975 python3-dateutil'
        self.assertEqual(
            txt.mltext2array(s, sort_key=0),
            [
                ['1662130757', 'python3-pip-wheel'],
                ['1662130953', 'timedatex'],
                ['1662130975', 'python3-dateutil'],
            ],
        )

    def test_skip_header_with_sort_key(self):
        self.assertEqual(
            txt.mltext2array('h1 h2\n3 b\n1 a', skip_header=True, sort_key=1),
            [['1', 'a'], ['3', 'b']],
        )


class TestMultiReplace(unittest.TestCase):
    def test_applies_all_replacements(self):
        self.assertEqual(
            txt.multi_replace('Hello World!', {'Hello': 'Hi', 'World': 'Universe'}),
            'Hi Universe!',
        )

    def test_empty_map_returns_input(self):
        self.assertEqual(txt.multi_replace('abc', {}), 'abc')


class TestPluralize(unittest.TestCase):
    def test_default_suffix(self):
        self.assertEqual(txt.pluralize('vote', 0), 'votes')
        self.assertEqual(txt.pluralize('vote', 1), 'vote')
        self.assertEqual(txt.pluralize('vote', 2), 'votes')

    def test_custom_suffix(self):
        self.assertEqual(txt.pluralize('class', 2, 'es'), 'classes')

    def test_singular_plural_pair(self):
        self.assertEqual(txt.pluralize('cand', 1, 'y,ies'), 'candy')
        self.assertEqual(txt.pluralize('cand', 2, 'y,ies'), 'candies')
        self.assertEqual(txt.pluralize('', 1, 'is,are'), 'is')
        self.assertEqual(txt.pluralize('', 2, 'is,are'), 'are')


class TestSanitizeSensitiveData(unittest.TestCase):
    def test_redacts_password(self):
        self.assertEqual(
            txt.sanitize_sensitive_data('user=admin&password=secret123'),
            'user=admin&password=******',
        )

    def test_custom_replacement(self):
        out = txt.sanitize_sensitive_data('api_key = xyz987', replacement='X')
        self.assertNotIn('xyz987', out)


class TestToBytes(unittest.TestCase):
    def test_str_and_int(self):
        self.assertEqual(txt.to_bytes('hello'), b'hello')
        self.assertEqual(txt.to_bytes(1234), b'1234')

    def test_encoding(self):
        self.assertEqual(txt.to_bytes('abc', encoding='latin-1'), b'abc')

    def test_none_empty(self):
        self.assertEqual(txt.to_bytes(None, nonstring='empty'), b'')

    def test_errors_replace(self):
        self.assertEqual(txt.to_bytes('café', encoding='ascii', errors='replace'), b'caf?')


class TestToText(unittest.TestCase):
    def test_bytes_and_str(self):
        self.assertEqual(txt.to_text(b'hello'), 'hello')
        self.assertEqual(txt.to_text('already text'), 'already text')

    def test_nonstring_empty(self):
        self.assertEqual(txt.to_text(None, nonstring='empty'), '')

    def test_strict_or_latin1_valid_utf8(self):
        self.assertEqual(txt.to_text('über'.encode(), errors='strict_or_latin1'), 'über')

    def test_strict_or_latin1_falls_back_on_invalid_utf8(self):
        # 0xfc is ü in Latin-1/CP1252 and an invalid UTF-8 start byte. With
        # surrogateescape it would decode to a lone surrogate and crash on the
        # later stdout re-encode; Latin-1 maps it to a real scalar instead (#256).
        self.assertEqual(txt.to_text(b'M\xfcller', errors='strict_or_latin1'), 'Müller')

    def test_strict_or_latin1_result_re_encodes_for_stdout(self):
        # The decoded text must survive a strict UTF-8 re-encode (what print()/stdout
        # does), which surrogateescape would not.
        txt.to_text(b'M\xfcller', errors='strict_or_latin1').encode('utf-8')

    def test_strict_or_latin1_str_passes_through(self):
        self.assertEqual(
            txt.to_text('already text', errors='strict_or_latin1'), 'already text'
        )

    def test_strict_or_latin1_every_byte_survives(self):
        # Latin-1 maps all 256 byte values, so no input can raise.
        self.assertEqual(
            len(txt.to_text(bytes(range(256)), errors='strict_or_latin1')), 256
        )


class TestUniq(unittest.TestCase):
    def test_dedups_tokens_preserving_order(self):
        self.assertEqual(txt.uniq('a a b a'), 'a b')
        self.assertEqual(
            txt.uniq('This is a test. This is a second test. And this is a third test.'),
            'This is a test. second And this third',
        )

    def test_empty_input(self):
        self.assertEqual(txt.uniq(''), '')


if __name__ == '__main__':
    unittest.main()
