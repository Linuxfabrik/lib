        self.assertFalse(success)
        self.assertEqual(result, 'Error getting statistics: {}')


# -----------------------------------------------------------------------------
# get_token
# -----------------------------------------------------------------------------


class TestGetToken(unittest.TestCase):
    """Assert login request building and credential extraction."""

    def test_endpoint_appended(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertEqual(captured['url'], BASE_URL + '/login')

    def test_trailing_slashes_stripped(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token('https://chat.example.com/api/v1///', 'admin', 'linuxfabrik')
        self.assertEqual(captured['url'], BASE_URL + '/login')

    def test_already_full_endpoint_not_doubled(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token(BASE_URL + '/login', 'admin', 'linuxfabrik')
        self.assertEqual(captured['url'], BASE_URL + '/login')

    def test_post_body_carries_credentials(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertEqual(captured['kw']['data'], {'user': 'admin', 'password': 'linuxfabrik'})

    def test_no_auth_headers_on_login(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertNotIn('header', captured['kw'])

    def test_transport_kwargs_forwarded(self):
        captured, ctx = patch_fetch((True, load_fixture('login.json')))
        with ctx:
            rocket.get_token(
                BASE_URL, 'admin', 'linuxfabrik', insecure=True, no_proxy=True, timeout=5
            )
        self.assertIs(captured['kw']['insecure'], True)
        self.assertIs(captured['kw']['no_proxy'], True)
        self.assertEqual(captured['kw']['timeout'], 5)

    def test_success_returns_token_colon_userid(self):
        payload = load_fixture('login.json')
        _, ctx = patch_fetch((True, payload))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertTrue(success)
        expected = '{}:{}'.format(
            payload['data']['authToken'], payload['data']['userId']
        )
        self.assertEqual(result, expected)

    def test_missing_data_block_is_auth_failure(self):
        _, ctx = patch_fetch((True, {'status': 'error', 'message': 'Unauthorized'}))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'wrong')
        self.assertFalse(success)
        self.assertEqual(result, 'Authentication failed or user unauthorized.')

    def test_missing_user_id_is_auth_failure(self):
        _, ctx = patch_fetch((True, {'data': {'authToken': 'AAA'}}))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertFalse(success)
        self.assertEqual(result, 'Authentication failed or user unauthorized.')

    def test_missing_auth_token_is_auth_failure(self):
        _, ctx = patch_fetch((True, {'data': {'userId': 'UUU'}}))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertFalse(success)
        self.assertEqual(result, 'Authentication failed or user unauthorized.')

    def test_empty_token_values_are_auth_failure(self):
        _, ctx = patch_fetch((True, {'data': {'authToken': '', 'userId': ''}}))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertFalse(success)
        self.assertEqual(result, 'Authentication failed or user unauthorized.')

    def test_transport_failure_wrapped(self):
        _, ctx = patch_fetch((False, 'connection refused'))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting token: connection refused')

    def test_empty_result_is_token_error(self):
        _, ctx = patch_fetch((True, {}))
        with ctx:
            success, result = rocket.get_token(BASE_URL, 'admin', 'linuxfabrik')
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting token: {}')


# -----------------------------------------------------------------------------
# send2webhook
# -----------------------------------------------------------------------------


class TestSend2Webhook(unittest.TestCase):
    """Assert webhook URL composition and POST handling."""

    def test_api_v1_segment_stripped_and_hooks_appended(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook(BASE_URL, 'CWaA/Zbpj', {'text': 'hi'})
        self.assertEqual(captured['url'], 'https://chat.example.com/hooks/CWaA/Zbpj')

    def test_base_url_without_api_v1(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook('https://chat.example.com', 'TOKEN', {'text': 'hi'})
        self.assertEqual(captured['url'], 'https://chat.example.com/hooks/TOKEN')

    def test_trailing_slash_stripped(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook('https://chat.example.com/', 'TOKEN', {'text': 'hi'})
        self.assertEqual(captured['url'], 'https://chat.example.com/hooks/TOKEN')

    def test_api_v1_with_trailing_slash(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook('https://chat.example.com/api/v1/', 'TOKEN', {'text': 'hi'})
        self.assertEqual(captured['url'], 'https://chat.example.com/hooks/TOKEN')

    def test_payload_posted_as_data(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        payload = {'text': 'Hello', 'channel': '#general'}
        with ctx:
            rocket.send2webhook(BASE_URL, 'TOKEN', payload)
        self.assertEqual(captured['kw']['data'], payload)

    def test_no_auth_headers_on_webhook(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertNotIn('header', captured['kw'])

    def test_transport_kwargs_forwarded(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook(
                BASE_URL, 'TOKEN', {'text': 'hi'},
                insecure=True, no_proxy=True, timeout=6,
            )
        self.assertIs(captured['kw']['insecure'], True)
        self.assertIs(captured['kw']['no_proxy'], True)
        self.assertEqual(captured['kw']['timeout'], 6)

    def test_default_transport_kwargs(self):
        captured, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertIs(captured['kw']['insecure'], False)
        self.assertIs(captured['kw']['no_proxy'], False)
        self.assertEqual(captured['kw']['timeout'], 3)

    def test_success_returns_true_true(self):
        _, ctx = patch_fetch((True, {'success': True}))
        with ctx:
            success, result = rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertTrue(success)
        self.assertIs(result, True)

    def test_success_normalizes_any_truthy_payload_to_true(self):
        # The function discards the payload and always returns True on success.
        _, ctx = patch_fetch((True, {'arbitrary': 'value'}))
        with ctx:
            success, result = rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertTrue(success)
        self.assertIs(result, True)

    def test_transport_failure_wrapped(self):
        _, ctx = patch_fetch((False, 'HTTP 500'))
        with ctx:
            success, result = rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertFalse(success)
        self.assertEqual(result, 'Error: HTTP 500')

    def test_empty_result_is_error(self):
        _, ctx = patch_fetch((True, {}))
        with ctx:
            success, result = rocket.send2webhook(BASE_URL, 'TOKEN', {'text': 'hi'})
        self.assertFalse(success)
        self.assertEqual(result, 'Error: {}')


if __name__ == '__main__':
    unittest.main()
