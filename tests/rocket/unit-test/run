        with ctx:
            rocket.get_rooms_get('https://chat.example.com/api/v1//', AUTH_TOKEN, USER_ID)
        self.assertEqual(captured['url'], BASE_URL + '/rooms.get')

    def test_already_full_endpoint_not_doubled(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(BASE_URL + '/rooms.get', AUTH_TOKEN, USER_ID)
        self.assertEqual(captured['url'], BASE_URL + '/rooms.get')

    def test_no_query_string(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertNotIn('?', captured['url'])

    def test_auth_headers_set(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertEqual(
            captured['kw']['header'],
            {'X-Auth-Token': AUTH_TOKEN, 'X-User-Id': USER_ID},
        )

    def test_default_transport_kwargs(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertIs(captured['kw']['insecure'], False)
        self.assertIs(captured['kw']['no_proxy'], False)
        self.assertEqual(captured['kw']['timeout'], 3)

    def test_transport_kwargs_forwarded(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(
                BASE_URL, AUTH_TOKEN, USER_ID, insecure=True, no_proxy=True, timeout=9
            )
        self.assertIs(captured['kw']['insecure'], True)
        self.assertIs(captured['kw']['no_proxy'], True)
        self.assertEqual(captured['kw']['timeout'], 9)

    def test_success_passes_through_fixture(self):
        payload = load_fixture('rooms_get.json')
        _, ctx = patch_fetch((True, payload))
        with ctx:
            success, result = rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertTrue(success)
        self.assertIs(result, payload)
        self.assertEqual(len(result['update']), 2)

    def test_transport_failure_wrapped(self):
        _, ctx = patch_fetch((False, 'HTTP 401'))
        with ctx:
            success, result = rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting rooms.get: HTTP 401')

    def test_empty_result_is_error(self):
        _, ctx = patch_fetch((True, {}))
        with ctx:
            success, result = rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting rooms.get: {}')


