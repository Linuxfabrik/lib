class TestGetRoomsInfo(unittest.TestCase):
    """Assert request building and response handling for rooms.info."""

    def test_endpoint_appended(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123')
        self.assertTrue(captured['url'].startswith(BASE_URL + '/rooms.info?'))

    def test_already_full_endpoint_not_doubled(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(
                BASE_URL + '/rooms.info', AUTH_TOKEN, USER_ID, room_id='ABC123'
            )
        self.assertEqual(captured['url'].count('/rooms.info'), 1)

    def test_room_id_in_query(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123')
        self.assertEqual(
            captured['url'], BASE_URL + '/rooms.info?roomId=ABC123&roomName=None'
        )

    def test_room_name_in_query(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(BASE_URL, AUTH_TOKEN, USER_ID, room_name='general')
        self.assertEqual(
            captured['url'], BASE_URL + '/rooms.info?roomId=None&roomName=general'
        )

    def test_both_id_and_name(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(
                BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123', room_name='ops'
            )
        self.assertEqual(
            captured['url'], BASE_URL + '/rooms.info?roomId=ABC123&roomName=ops'
        )

    def test_neither_id_nor_name_still_emits_none_query(self):
        # Both keys are always present, so the query is never empty here.
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertEqual(
            captured['url'], BASE_URL + '/rooms.info?roomId=None&roomName=None'
        )

    def test_auth_headers_set(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123')
        self.assertEqual(
            captured['kw']['header'],
            {'X-Auth-Token': AUTH_TOKEN, 'X-User-Id': USER_ID},
        )

    def test_transport_kwargs_forwarded(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_info(
                BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123',
                insecure=True, no_proxy=True, timeout=7,
            )
        self.assertIs(captured['kw']['insecure'], True)
        self.assertIs(captured['kw']['no_proxy'], True)
        self.assertEqual(captured['kw']['timeout'], 7)

    def test_success_passes_through_fixture(self):
        payload = load_fixture('rooms_info.json')
        _, ctx = patch_fetch((True, payload))
        with ctx:
            success, result = rocket.get_rooms_info(
                BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123'
            )
        self.assertTrue(success)
        self.assertIs(result, payload)
        self.assertEqual(result['room']['name'], 'ops-private')

    def test_transport_failure_wrapped(self):
        _, ctx = patch_fetch((False, 'room not found'))
        with ctx:
            success, result = rocket.get_rooms_info(
                BASE_URL, AUTH_TOKEN, USER_ID, room_id='nope'
            )
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting rooms.info: room not found')

    def test_empty_result_is_error(self):
        _, ctx = patch_fetch((True, {}))
        with ctx:
            success, result = rocket.get_rooms_info(
                BASE_URL, AUTH_TOKEN, USER_ID, room_id='ABC123'
            )
        self.assertFalse(success)
        self.assertEqual(result, 'Error getting rooms.info: {}')


