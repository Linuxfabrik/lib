    """Assert request building and response handling for rooms.get."""

    def test_endpoint_appended(self):
        captured, ctx = patch_fetch((True, {'ok': 1}))
        with ctx:
            rocket.get_rooms_get(BASE_URL, AUTH_TOKEN, USER_ID)
        self.assertEqual(captured['url'], BASE_URL + '/rooms.get')

    def test_trailing_slashes_stripped(self):
