"""Unit tests for lib.shell.

shell_exec() always runs with shell=False and requires the command as a list of
arguments (argv). It is exercised by mocking subprocess.Popen so the OS layer is
fully stubbed. A small set of end-to-end checks against trivial real commands
(echo / true / false / cat) is guarded behind a POSIX check and also asserts the
core security property: shell metacharacters in an argument stay literal.
"""

import os
import subprocess
import sys
import typing
import unittest
from unittest import mock

sys.path.insert(0, '..')

import lib.shell as shell

# ---------------------------------------------------------------------------
# Helpers / fakes
# ---------------------------------------------------------------------------

class FakePopen:
    """Minimal stand-in for subprocess.Popen.

    Records the args/kwargs it was constructed with so tests can assert on how
    shell_exec wired up the process, and returns canned communicate() output.
    """

    instances: typing.ClassVar = []

    def __init__(self, *args, **kwargs):
        self.args = args
        self.kwargs = kwargs
        recipe = type(self)._recipe
        self._stdout_bytes = recipe.get('stdout', b'')
        self._stderr_bytes = recipe.get('stderr', b'')
        self.returncode = recipe.get('returncode', 0)
        self._timeout = recipe.get('timeout', False)
        self.killed = False
        self.stdout = mock.MagicMock(name='stdout-pipe')
        type(self).instances.append(self)

    def communicate(self, input=None, timeout=None):
        self.last_input = input
        self.last_timeout = timeout
        if self._timeout:
            self._timeout = False
            raise subprocess.TimeoutExpired(cmd='x', timeout=timeout)
        return self._stdout_bytes, self._stderr_bytes

    def kill(self):
        self.killed = True

    _recipe: typing.ClassVar = {}


def make_popen(stdout=b'', stderr=b'', returncode=0, timeout=False):
    """Build a FakePopen subclass primed with a single canned result."""

    class _Primed(FakePopen):
        instances: typing.ClassVar = []
        _recipe: typing.ClassVar = {
            'stdout': stdout,
            'stderr': stderr,
            'returncode': returncode,
            'timeout': timeout,
        }

    return _Primed


# ---------------------------------------------------------------------------
# shell_exec() - argument type guard
# ---------------------------------------------------------------------------

class TestShellExecRequiresList(unittest.TestCase):
    def test_string_raises_type_error(self):
        with self.assertRaises(TypeError):
            shell.shell_exec('ls -l')

    def test_type_error_message_mentions_list(self):
        with self.assertRaises(TypeError) as ctx:
            shell.shell_exec('ls -l')
        self.assertIn('list', str(ctx.exception))

    def test_tuple_is_accepted(self):
        Fake = make_popen(stdout=b'ok\n')
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            success, result = shell.shell_exec(('true',))
        self.assertTrue(success)
        self.assertEqual(result, ('ok\n', '', 0))


# ---------------------------------------------------------------------------
# shell_exec() - process wiring (mocked Popen)
# ---------------------------------------------------------------------------

class TestShellExec(unittest.TestCase):
    def test_single_command_success(self):
        Fake = make_popen(stdout=b'out\n', stderr=b'err\n', returncode=0)
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            success, result = shell.shell_exec(['ls', '-l'])
        self.assertTrue(success)
        self.assertEqual(result, ('out\n', 'err\n', 0))

    def test_cmd_is_passed_verbatim_as_argv(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['ls', '-l', '/tmp/a b'])
        # The list is handed to Popen unchanged: no splitting, no joining.
        self.assertEqual(Fake.instances[0].args[0], ['ls', '-l', '/tmp/a b'])

    def test_always_uses_shell_false(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'])
        self.assertFalse(Fake.instances[0].kwargs['shell'])

    def test_metacharacters_stay_literal_arguments(self):
        # An argument that looks like a shell pipeline/redirect must reach Popen
        # as a single literal element, never split or interpreted.
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['echo', '|reboot| ; rm -rf / && evil'])
        self.assertEqual(
            Fake.instances[0].args[0], ['echo', '|reboot| ; rm -rf / && evil']
        )
        # exactly one process, no pipeline splitting
        self.assertEqual(len(Fake.instances), 1)

    def test_returncode_is_propagated(self):
        Fake = make_popen(stdout=b'', stderr=b'nope\n', returncode=2)
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            success, result = shell.shell_exec(['false'])
        self.assertTrue(success)
        self.assertEqual(result[2], 2)

    def test_lc_all_defaults_to_C(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'])
        self.assertEqual(Fake.instances[0].kwargs['env']['LC_ALL'], 'C')

    def test_lc_all_override(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'], lc_all='en_US.UTF-8')
        self.assertEqual(Fake.instances[0].kwargs['env']['LC_ALL'], 'en_US.UTF-8')

    def test_env_is_merged_with_os_environ(self):
        Fake = make_popen()
        with (
            mock.patch.dict(os.environ, {'EXISTING': 'keep'}, clear=False),
            mock.patch.object(shell.subprocess, 'Popen', Fake),
        ):
            shell.shell_exec(['true'], env={'CUSTOM': 'value'})
        env = Fake.instances[0].kwargs['env']
        self.assertEqual(env['CUSTOM'], 'value')
        self.assertEqual(env['EXISTING'], 'keep')

    def test_caller_env_does_not_mutate_os_environ(self):
        Fake = make_popen()
        before = dict(os.environ)
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'], env={'TRANSIENT': 'x'})
        self.assertNotIn('TRANSIENT', os.environ)
        self.assertEqual(dict(os.environ), before)

    def test_cwd_is_passed_through(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'], cwd='/tmp')
        self.assertEqual(Fake.instances[0].kwargs['cwd'], '/tmp')

    def test_timeout_is_passed_to_communicate(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'], timeout=5)
        self.assertEqual(Fake.instances[0].last_timeout, 5)

    def test_stdin_is_encoded_to_bytes(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['cat'], stdin='hello')
        self.assertEqual(Fake.instances[0].last_input, b'hello')

    def test_no_stdin_passes_none_to_communicate(self):
        Fake = make_popen()
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            shell.shell_exec(['true'])
        self.assertIsNone(Fake.instances[0].last_input)

    def test_popen_construction_error_returns_false(self):
        def boom(*args, **kwargs):
            raise OSError('No such file or directory')

        with mock.patch.object(shell.subprocess, 'Popen', boom):
            success, result = shell.shell_exec(['nonexistent-binary'])
        self.assertFalse(success)
        self.assertIn('Error', result)
        self.assertIn('nonexistent-binary', result)

    def test_value_error_during_construction_returns_false(self):
        def boom(*args, **kwargs):
            raise ValueError('bad args')

        with mock.patch.object(shell.subprocess, 'Popen', boom):
            success, result = shell.shell_exec(['weird'])
        self.assertFalse(success)
        self.assertIn('bad args', result)

    def test_timeout_expired_kills_and_reports(self):
        Fake = make_popen(timeout=True)
        with mock.patch.object(shell.subprocess, 'Popen', Fake):
            success, result = shell.shell_exec(['sleep', '100'], timeout=1)
        self.assertFalse(success)
        self.assertEqual(result, 'Timeout after 1 seconds.')
        self.assertTrue(Fake.instances[0].killed)

    def test_posix_decodes_utf8(self):
        # 'ü' as UTF-8 (0xc3 0xbc) decodes cleanly on POSIX.
        Fake = make_popen(stdout=b'm\xc3\xbcller\n')
        with (
            mock.patch.object(shell.os, 'name', 'posix'),
            mock.patch.object(shell.subprocess, 'Popen', Fake),
        ):
            _success, result = shell.shell_exec(['echo'])
        self.assertEqual(result[0], 'müller\n')

    def test_posix_non_utf8_falls_back_to_latin1(self):
        # A non-UTF-8 byte (0xfc = ü in Latin-1/CP1252) must decode via Latin-1,
        # not surrogateescape: a lone surrogate would decode here but crash later
        # when the plugin re-encodes the message for stdout (Linuxfabrik/lib#256).
        Fake = make_popen(stdout=b'M\xfcller\n')
        with (
            mock.patch.object(shell.os, 'name', 'posix'),
            mock.patch.object(shell.subprocess, 'Popen', Fake),
        ):
            _success, result = shell.shell_exec(['echo'])
        self.assertEqual(result[0], 'Müller\n')
        result[0].encode('utf-8')  # would raise under surrogateescape

    def test_windows_decodes_with_console_code_page(self):
        # 'ü' from a console program is OEM cp437 (byte 0x81), not UTF-8. The
        # Windows path must decode with the console output code page so the
        # username is not mangled (monitoring-plugins#681).
        Fake = make_popen(stdout=b'm\x81ller\n')
        with (
            mock.patch.object(shell.os, 'name', 'nt'),
            mock.patch.object(shell, '_windows_output_encoding', return_value='cp437'),
            mock.patch.object(shell.subprocess, 'Popen', Fake),
        ):
            _success, result = shell.shell_exec(['query', 'user'])
        self.assertEqual(result[0], 'müller\n')


# ---------------------------------------------------------------------------
# safe_cli_value()
# ---------------------------------------------------------------------------

class TestSafeCliValue(unittest.TestCase):
    def test_plain_value_passes(self):
        self.assertEqual(
            shell.safe_cli_value('host.example', '--hostname'),
            (True, 'host.example'),
        )

    def test_leading_dash_is_rejected(self):
        ok, msg = shell.safe_cli_value('-oProxyCommand=evil', '--hostname')
        self.assertFalse(ok)
        self.assertIn('--hostname', msg)

    def test_single_dash_is_rejected(self):
        ok, _msg = shell.safe_cli_value('-f', '--hostname')
        self.assertFalse(ok)

    def test_non_string_passes_through(self):
        self.assertEqual(shell.safe_cli_value(5, 'count'), (True, 5))
        self.assertEqual(shell.safe_cli_value(None, 'thing'), (True, None))

    def test_value_with_inner_dash_passes(self):
        self.assertEqual(
            shell.safe_cli_value('some-host', '--hostname'),
            (True, 'some-host'),
        )


# ---------------------------------------------------------------------------
# End-to-end smoke checks against trivial real commands (POSIX only).
# These also assert the security property against a real subprocess.
# ---------------------------------------------------------------------------

@unittest.skipUnless(os.name == 'posix', 'POSIX-only smoke checks')
class TestShellExecRealCommands(unittest.TestCase):
    def test_echo_roundtrip(self):
        success, result = shell.shell_exec(['echo', 'linuxfabrik'])
        self.assertTrue(success)
        self.assertEqual(result[0].strip(), 'linuxfabrik')
        self.assertEqual(result[2], 0)

    def test_false_returns_nonzero(self):
        success, result = shell.shell_exec(['false'])
        self.assertTrue(success)
        self.assertNotEqual(result[2], 0)

    def test_real_stdin(self):
        success, result = shell.shell_exec(['cat'], stdin='from-stdin')
        self.assertTrue(success)
        self.assertEqual(result[0].strip(), 'from-stdin')

    def test_real_timeout(self):
        success, result = shell.shell_exec(['sleep', '5'], timeout=1)
        self.assertFalse(success)
        self.assertEqual(result, 'Timeout after 1 seconds.')

    def test_metacharacters_are_not_interpreted(self):
        # The whole string is one literal argument to echo; the shell would have
        # split it on '|' and run 'reboot'. shell=False means it never does.
        payload = '|reboot| ; rm -rf / && whoami'
        success, result = shell.shell_exec(['echo', payload])
        self.assertTrue(success)
        self.assertEqual(result[0].strip(), payload)

    def test_argument_with_spaces_stays_single(self):
        success, result = shell.shell_exec(['echo', 'one two three'])
        self.assertTrue(success)
        self.assertEqual(result[0].strip(), 'one two three')


class TestWhich(unittest.TestCase):
    def test_found(self):
        with mock.patch('lib.shell.shutil.which', return_value='/usr/bin/sh') as w:
            self.assertEqual(shell.which('sh'), '/usr/bin/sh')
            w.assert_called_once_with('sh')

    def test_not_found(self):
        with mock.patch('lib.shell.shutil.which', return_value=None):
            self.assertIsNone(shell.which('does-not-exist'))


if __name__ == '__main__':
    unittest.main()
