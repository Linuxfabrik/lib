"""Unit tests for lib.time. No fixtures or containers.

epoch2iso() renders in local time, so the timezone-sensitive cases pin
TZ=UTC for reproducibility.
"""

import datetime
import os
import sys
import time as _time
import unittest

sys.path.insert(0, '..')

import lib.time as t


class TestTimezonePinned(unittest.TestCase):
    """Cases that depend on the local timezone; pinned to UTC."""

    def setUp(self):
        self.saved_tz = os.environ.get('TZ')
        os.environ['TZ'] = 'UTC'
        _time.tzset()

    def tearDown(self):
        if self.saved_tz is None:
            os.environ.pop('TZ', None)
        else:
            os.environ['TZ'] = self.saved_tz
        _time.tzset()

    def test_epoch2iso(self):
        self.assertEqual(t.epoch2iso(1609459200), '2021-01-01 00:00:00')

    def test_epoch2iso_unix_epoch_zero(self):
        self.assertEqual(t.epoch2iso(0), '1970-01-01 00:00:00')

    def test_epoch2iso_negative_predates_epoch(self):
        self.assertEqual(t.epoch2iso(-100), '1969-12-31 23:58:20')

    def test_get_weekday(self):
        self.assertEqual(t.get_weekday(1609459200), 'fri')
        self.assertEqual(t.get_weekday(0), 'thu')  # 1970-01-01 was a Thursday

    def test_timestr2epoch(self):
        self.assertEqual(t.timestr2epoch('2021-01-01 00:00:00'), 1609459200.0)
        self.assertEqual(t.timestr2epoch('1970-01-01 00:00:00'), 0.0)


class TestTimezoneIndependent(unittest.TestCase):
    def test_timestr2datetime(self):
        self.assertEqual(
            t.timestr2datetime('2021-01-01 00:00:00'),
            datetime.datetime(2021, 1, 1, 0, 0),
        )

    def test_timestrdiff(self):
        self.assertEqual(
            t.timestrdiff('2021-01-01 00:00:10', '2021-01-01 00:00:00'),
            10.0,
        )

    def test_timestrdiff_equal_is_zero(self):
        self.assertEqual(
            t.timestrdiff('2021-01-01 00:00:00', '2021-01-01 00:00:00'),
            0.0,
        )

    def test_timestr2epoch_iso8601(self):
        # pattern='iso8601' parses a trailing 'Z', an embedded offset and a
        # date-only value; all three below denote the same instant in UTC.
        self.assertEqual(
            t.timestr2epoch('2021-01-01T00:00:00Z', pattern='iso8601'), 1609459200.0
        )
        self.assertEqual(
            t.timestr2epoch('2021-01-01T02:00:00+02:00', pattern='iso8601'),
            1609459200.0,
        )
        self.assertEqual(
            t.timestr2epoch(
                '2021-01-01', pattern='iso8601', tzinfo=datetime.timezone.utc
            ),
            1609459200.0,
        )

    def test_timestr2epoch_iso8601_invalid_raises(self):
        with self.assertRaises(ValueError):
            t.timestr2epoch('not a date', pattern='iso8601')

    def test_timestr2epoch_invalid_pattern_raises(self):
        # only the exact 'iso8601' sentinel enables ISO parsing; any other
        # pattern is treated as a strptime format, so a near-miss sentinel
        # ('iso') does not parse an ISO string and raises.
        with self.assertRaises(ValueError):
            t.timestr2epoch('2021-01-01T00:00:00Z', pattern='iso')

    def test_get_timezone(self):
        self.assertEqual(str(t.get_timezone('UTC')), 'UTC')

    def test_utc_offset_is_string(self):
        self.assertIsInstance(t.utc_offset(), str)


class TestNow(unittest.TestCase):
    def test_epoch_default(self):
        self.assertIsInstance(t.now(), int)
        self.assertGreater(t.now(), 0)

    def test_datetime_type(self):
        self.assertIsInstance(t.now('datetime'), datetime.datetime)


class TestMacro2Timestr(unittest.TestCase):
    def test_passthrough_without_macro(self):
        self.assertEqual(t.macro2timestr('plain.log', format='%Y%m%d'), 'plain.log')

    def test_strftime_component_expands(self):
        expected = datetime.date.today().strftime('%Y') + '.log'
        self.assertEqual(t.macro2timestr('{%Y}.log', format='%Y%m%d'), expected)


class TestBadInput(unittest.TestCase):
    def test_epoch2iso_non_numeric_is_empty(self):
        # Documented graceful behaviour: unparseable input yields ''.
        self.assertEqual(t.epoch2iso('abc'), '')

    def test_timestr2epoch_invalid_raises(self):
        with self.assertRaises(ValueError):
            t.timestr2epoch('not a date')


if __name__ == '__main__':
    unittest.main()
