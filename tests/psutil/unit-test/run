"""Unit tests for lib.psutil.

The only public helper is get_partitions, a thin filter over
psutil.disk_partitions. psutil itself is mocked so the suite is hermetic
and does not depend on the host's mount table.
"""

import collections
import sys
import unittest
from unittest import mock

sys.path.insert(0, '..')

try:
    import lib.psutil as lib_psutil
    HAVE_PSUTIL = True
except SystemExit:
    # lib.psutil sys.exit()s with STATE_UNKNOWN when psutil is missing.
    HAVE_PSUTIL = False


# Mirror the named tuple psutil.disk_partitions() returns. The real one
# also carries opts/maxfile/maxpath, but get_partitions only ever touches
# .mountpoint, so a minimal stand-in keeps the fixtures readable while
# still exercising the named-tuple access path.
sdiskpart = collections.namedtuple('sdiskpart', ['device', 'mountpoint', 'fstype'])


def sample_partitions():
    """Realistic set of mounted partitions on a Linux host."""
    return [
        sdiskpart('/dev/sda1', '/', 'ext4'),
        sdiskpart('/dev/sda2', '/boot', 'ext4'),
        sdiskpart('/dev/sdb1', '/mnt/backup', 'xfs'),
        sdiskpart('/dev/mapper/vg-home', '/home', 'ext4'),
        sdiskpart('/dev/sdc1', '/var/lib/docker', 'btrfs'),
    ]


@unittest.skipUnless(HAVE_PSUTIL, 'psutil module not installed')
class TestGetPartitions(unittest.TestCase):
    def setUp(self):
        # Patch the psutil reference imported into lib.psutil so no real
        # disk introspection happens during the tests.
        patcher = mock.patch.object(lib_psutil, 'psutil')
        self.mock_psutil = patcher.start()
        self.addCleanup(patcher.stop)
        self.mock_psutil.disk_partitions.return_value = sample_partitions()

    def test_returns_all_when_no_ignore(self):
        result = lib_psutil.get_partitions()
        self.assertEqual(len(result), 5)
        self.assertEqual(result, sample_partitions())

    def test_calls_disk_partitions_with_all_false(self):
        # Physical-only behaviour (mirrors df) must be preserved.
        lib_psutil.get_partitions()
        self.mock_psutil.disk_partitions.assert_called_once_with(all=False)

    def test_default_ignore_is_none_keeps_everything(self):
        self.assertEqual(lib_psutil.get_partitions(None), sample_partitions())

    def test_empty_ignore_list_keeps_everything(self):
        self.assertEqual(lib_psutil.get_partitions([]), sample_partitions())

    def test_ignore_single_mountpoint(self):
        result = lib_psutil.get_partitions(['/boot'])
        mountpoints = [p.mountpoint for p in result]
        self.assertNotIn('/boot', mountpoints)
        self.assertEqual(len(result), 4)

    def test_ignore_multiple_mountpoints(self):
        result = lib_psutil.get_partitions(['/boot', '/home'])
        mountpoints = [p.mountpoint for p in result]
        self.assertNotIn('/boot', mountpoints)
        self.assertNotIn('/home', mountpoints)
        self.assertEqual(len(result), 3)

    def test_ignore_is_substring_match(self):
        # '/var' is not an exact mountpoint, but it is a substring of
        # '/var/lib/docker', so that partition must be dropped.
        result = lib_psutil.get_partitions(['/var'])
        mountpoints = [p.mountpoint for p in result]
        self.assertNotIn('/var/lib/docker', mountpoints)
        self.assertEqual(len(result), 4)

    def test_ignore_substring_can_match_many(self):
        # '/' is a substring of every mountpoint, so everything is dropped.
        self.assertEqual(lib_psutil.get_partitions(['/']), [])

    def test_ignore_no_match_keeps_everything(self):
        self.assertEqual(
            lib_psutil.get_partitions(['/nonexistent']),
            sample_partitions(),
        )

    def test_ignore_filters_empty_strings(self):
        # filter(None, ...) drops '' so it must NOT match every mountpoint.
        # Without the filter, the '' substring would wipe out all partitions.
        result = lib_psutil.get_partitions(['', '/boot'])
        mountpoints = [p.mountpoint for p in result]
        self.assertNotIn('/boot', mountpoints)
        self.assertEqual(len(result), 4)

    def test_ignore_only_empty_strings_keeps_everything(self):
        self.assertEqual(lib_psutil.get_partitions(['', '']), sample_partitions())

    def test_ignore_none_entries_are_dropped(self):
        # filter(None, ...) also strips None, which would otherwise raise
        # on the substring `in` check.
        result = lib_psutil.get_partitions([None, '/boot'])
        mountpoints = [p.mountpoint for p in result]
        self.assertNotIn('/boot', mountpoints)
        self.assertEqual(len(result), 4)

    def test_returns_list_type(self):
        self.assertIsInstance(lib_psutil.get_partitions(), list)

    def test_empty_partition_table(self):
        self.mock_psutil.disk_partitions.return_value = []
        self.assertEqual(lib_psutil.get_partitions(), [])
        self.assertEqual(lib_psutil.get_partitions(['/boot']), [])

    def test_namedtuple_fields_are_preserved(self):
        result = lib_psutil.get_partitions(['/boot', '/home', '/mnt', '/var'])
        self.assertEqual(len(result), 1)
        part = result[0]
        self.assertEqual(part.device, '/dev/sda1')
        self.assertEqual(part.mountpoint, '/')
        self.assertEqual(part.fstype, 'ext4')


if __name__ == '__main__':
    unittest.main()
