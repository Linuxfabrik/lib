"""Unit tests for lib.icinga.

All six public functions are covered hermetically. The module only talks to
the outside world through lib.url.fetch_json (HTTP) and time.sleep (throttle),
so both are mocked. No network call and no real sleep ever happens.

Public functions under test:

- api_post()         -> low-level POST, builds auth header + method override
- get_service()      -> GET-override query on /v1/objects/services
- remove_ack()       -> POST /v1/actions/remove-acknowledgement
- remove_downtime()  -> POST /v1/actions/remove-downtime
- set_ack()          -> POST /v1/actions/acknowledge-problem
- set_downtime()     -> POST /v1/actions/schedule-downtime, parses the result

Each higher-level function is asserted both end-to-end (URL + payload as seen
by fetch_json) and via the api_post seam, so a refactor of either layer keeps
the contract pinned.
"""

import base64
import sys
import unittest
from unittest import mock

sys.path.insert(0, '..')

import lib.icinga as icinga

URI = 'https://icinga-server:5665'
USER = 'linuxfabrik'
PASSWORD = 'linuxfabrik'

# Auth header that api_post must produce for the credentials above.
EXPECTED_AUTH = 'Basic ' + base64.b64encode(b'linuxfabrik:linuxfabrik').decode()


def make_fetch_json(return_value=(True, {'ok': True})):
    """Return a MagicMock standing in for url.fetch_json with a canned result."""
    return mock.MagicMock(name='fetch_json', return_value=return_value)


class IcingaTestBase(unittest.TestCase):
    """Patches url.fetch_json and time.sleep for every test.

    self.fetch_json is the mock; self.last_call() returns its kwargs so the
    request crafted by the module can be asserted on.
    """

    def setUp(self):
        self.fetch_json = make_fetch_json()
        self._p_fetch = mock.patch.object(icinga.url, 'fetch_json', self.fetch_json)
        # Patch the time.sleep that the module imported, so the throttle is a
        # no-op and the suite stays fast.
        self._p_sleep = mock.patch.object(icinga.time, 'sleep')
        self._p_fetch.start()
        self.sleep = self._p_sleep.start()
        self.addCleanup(self._p_fetch.stop)
        self.addCleanup(self._p_sleep.stop)

    def last_call(self):
        """Return (args, kwargs) of the most recent fetch_json call."""
        self.assertTrue(self.fetch_json.called, 'fetch_json was never called')
        return self.fetch_json.call_args

    def sent_uri(self):
        """First positional arg passed to fetch_json (the URI)."""
        return self.last_call().args[0]

    def sent_kwargs(self):
        return self.last_call().kwargs


# ---------------------------------------------------------------------------
# api_post()
# ---------------------------------------------------------------------------


class TestApiPost(IcingaTestBase):
    def test_returns_fetch_json_result_unchanged(self):
        sentinel = (True, {'results': [{'code': 200}]})
        self.fetch_json.return_value = sentinel
        result = icinga.api_post(f'{URI}/v1/objects/services', USER, PASSWORD)
        self.assertIs(result, sentinel)

    def test_failure_result_passed_through(self):
        self.fetch_json.return_value = (False, 'connection refused')
        success, body = icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertFalse(success)
        self.assertEqual(body, 'connection refused')

    def test_auth_header_is_base64_basic(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        headers = self.sent_kwargs()['header']
        self.assertEqual(headers['Authorization'], EXPECTED_AUTH)

    def test_auth_header_decodes_to_user_colon_password(self):
        icinga.api_post(f'{URI}/v1/x', 'alice', 's3cret')
        token = self.sent_kwargs()['header']['Authorization'].split(' ', 1)[1]
        self.assertEqual(base64.b64decode(token).decode(), 'alice:s3cret')

    def test_accept_header_is_json(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertEqual(self.sent_kwargs()['header']['Accept'], 'application/json')

    def test_method_override_header_set_when_given(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, method_override='GET')
        self.assertEqual(self.sent_kwargs()['header']['X-HTTP-Method-Override'], 'GET')

    def test_method_override_header_absent_by_default(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertNotIn('X-HTTP-Method-Override', self.sent_kwargs()['header'])

    def test_empty_method_override_does_not_add_header(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, method_override='')
        self.assertNotIn('X-HTTP-Method-Override', self.sent_kwargs()['header'])

    def test_double_slash_v1_is_normalised(self):
        icinga.api_post(f'{URI}//v1/objects/services', USER, PASSWORD)
        self.assertEqual(self.sent_uri(), f'{URI}/v1/objects/services')

    def test_double_slash_v2_is_normalised(self):
        icinga.api_post(f'{URI}//v2/foo', USER, PASSWORD)
        self.assertEqual(self.sent_uri(), f'{URI}/v2/foo')

    def test_single_slash_uri_left_intact(self):
        icinga.api_post(f'{URI}/v1/objects/services', USER, PASSWORD)
        self.assertEqual(self.sent_uri(), f'{URI}/v1/objects/services')

    def test_data_none_becomes_empty_dict(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, data=None)
        self.assertEqual(self.sent_kwargs()['data'], {})

    def test_data_passed_through(self):
        payload = {'filter': 'x', 'attrs': ['name', 'state']}
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, data=payload)
        self.assertEqual(self.sent_kwargs()['data'], payload)

    def test_encoding_is_serialized_json(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertEqual(self.sent_kwargs()['encoding'], 'serialized-json')

    def test_insecure_forwarded(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, insecure=True)
        self.assertTrue(self.sent_kwargs()['insecure'])

    def test_insecure_default_false(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertFalse(self.sent_kwargs()['insecure'])

    def test_no_proxy_forwarded(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, no_proxy=True)
        self.assertTrue(self.sent_kwargs()['no_proxy'])

    def test_timeout_forwarded(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD, timeout=42)
        self.assertEqual(self.sent_kwargs()['timeout'], 42)

    def test_timeout_default_is_three(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.assertEqual(self.sent_kwargs()['timeout'], 3)

    def test_sleeps_default_amount_after_call(self):
        icinga.api_post(f'{URI}/v1/x', USER, PASSWORD)
        self.sleep.assert_called_once_with(icinga.DEFAULT_SLEEP)

    def test_default_sleep_constant_value(self):
        self.assertEqual(icinga.DEFAULT_SLEEP, 1.0)


# ---------------------------------------------------------------------------
# get_service()
# ---------------------------------------------------------------------------


class TestGetService(IcingaTestBase):
    def test_uri_targets_services_endpoint(self):
        icinga.get_service(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/objects/services')

    def test_trailing_slash_in_base_uri_stripped(self):
        icinga.get_service(URI + '/', USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/objects/services')

    def test_uses_get_method_override(self):
        icinga.get_service(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_kwargs()['header']['X-HTTP-Method-Override'], 'GET')

    def test_filter_matches_service_name(self):
        icinga.get_service(URI, USER, PASSWORD, 'host!special-service')
        data = self.sent_kwargs()['data']
        self.assertEqual(
            data['filter'], 'match("host!special-service", service.__name)'
        )

    def test_default_attrs_is_name_plus_state(self):
        icinga.get_service(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_kwargs()['data']['attrs'], ['name', 'state'])

    def test_custom_attrs_are_split_and_prefixed_with_name(self):
        icinga.get_service(
            URI, USER, PASSWORD, 'host!svc', attrs='state,acknowledgement'
        )
        self.assertEqual(
            self.sent_kwargs()['data']['attrs'],
            ['name', 'state', 'acknowledgement'],
        )

    def test_returns_api_post_result(self):
        sentinel = (True, {'result': [{'attrs': {'state': 2}}]})
        self.fetch_json.return_value = sentinel
        self.assertIs(icinga.get_service(URI, USER, PASSWORD, 'host!svc'), sentinel)

    def test_forwards_insecure_no_proxy_timeout(self):
        icinga.get_service(
            URI,
            USER,
            PASSWORD,
            'host!svc',
            insecure=True,
            no_proxy=True,
            timeout=9,
        )
        kw = self.sent_kwargs()
        self.assertTrue(kw['insecure'])
        self.assertTrue(kw['no_proxy'])
        self.assertEqual(kw['timeout'], 9)


