class TestRemoveAck(IcingaTestBase):
    def test_uri_targets_remove_acknowledgement(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/actions/remove-acknowledgement')

    def test_trailing_slash_stripped(self):
        icinga.remove_ack(URI + '/', USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/actions/remove-acknowledgement')

    def test_default_type_is_service_capitalised(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(self.sent_kwargs()['data']['type'], 'Service')

    def test_default_filter_uses_lower_service(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host!svc')
        self.assertEqual(
            self.sent_kwargs()['data']['filter'],
            'match("host!svc", service.__name)',
        )

    def test_host_type_capitalised_in_type(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host', _type='host')
        self.assertEqual(self.sent_kwargs()['data']['type'], 'Host')

    def test_host_type_lowered_in_filter(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host', _type='host')
        self.assertEqual(
            self.sent_kwargs()['data']['filter'], 'match("host", host.__name)'
        )

    def test_no_method_override(self):
        icinga.remove_ack(URI, USER, PASSWORD, 'host!svc')
        self.assertNotIn('X-HTTP-Method-Override', self.sent_kwargs()['header'])

    def test_returns_api_post_result(self):
        sentinel = (True, {'results': [{'code': 200}]})
        self.fetch_json.return_value = sentinel
        self.assertIs(icinga.remove_ack(URI, USER, PASSWORD, 'host!svc'), sentinel)

    def test_forwards_insecure_no_proxy_timeout(self):
        icinga.remove_ack(
            URI,
            USER,
            PASSWORD,
            'host!svc',
            insecure=True,
            no_proxy=True,
            timeout=11,
        )
        kw = self.sent_kwargs()
        self.assertTrue(kw['insecure'])
        self.assertTrue(kw['no_proxy'])
        self.assertEqual(kw['timeout'], 11)


# ---------------------------------------------------------------------------
# remove_downtime()
# ---------------------------------------------------------------------------


class TestRemoveDowntime(IcingaTestBase):
    def test_uri_targets_remove_downtime(self):
        icinga.remove_downtime(URI, USER, PASSWORD, 'host!svc!uuid')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/actions/remove-downtime')

    def test_downtime_name_in_payload(self):
        icinga.remove_downtime(URI, USER, PASSWORD, 'host!svc!uuid')
        self.assertEqual(self.sent_kwargs()['data'], {'downtime': 'host!svc!uuid'})

    def test_no_method_override(self):
        icinga.remove_downtime(URI, USER, PASSWORD, 'host!svc!uuid')
        self.assertNotIn('X-HTTP-Method-Override', self.sent_kwargs()['header'])

    def test_returns_api_post_result(self):
        sentinel = (True, {'results': [{'code': 200}]})
        self.fetch_json.return_value = sentinel
        self.assertIs(
            icinga.remove_downtime(URI, USER, PASSWORD, 'host!svc!uuid'), sentinel
        )

    def test_trailing_slash_in_base_uri_normalised_by_api_post(self):
        # remove_downtime concatenates without rstrip, producing '//v1', but
        # api_post collapses '//v1' back to '/v1', so the trailing slash is
        # tolerated end-to-end.
        icinga.remove_downtime(URI + '/', USER, PASSWORD, 'dt')
        self.assertEqual(self.sent_uri(), f'{URI}/v1/actions/remove-downtime')

    def test_forwards_insecure_no_proxy_timeout(self):
        icinga.remove_downtime(
            URI, USER, PASSWORD, 'dt', insecure=True, no_proxy=True, timeout=7
        )
        kw = self.sent_kwargs()
        self.assertTrue(kw['insecure'])
        self.assertTrue(kw['no_proxy'])
        self.assertEqual(kw['timeout'], 7)


