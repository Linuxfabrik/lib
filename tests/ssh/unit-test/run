"""Unit tests for lib.ssh.

build_options() and target() are pure. run(), scp() and rsync() are exercised
by mocking lib.shell.shell_exec, so the assembled command line is asserted
without spawning ssh/scp/rsync.
"""

import sys
import unittest
from unittest import mock

sys.path.insert(0, '..')

import lib.ssh as ssh


class TestBuildOptions(unittest.TestCase):
    def test_empty(self):
        self.assertEqual(ssh.build_options(), '')

    def test_typical_non_interactive(self):
        self.assertEqual(
            ssh.build_options(
                identity=['~/.ssh/id_ed25519'],
                batch_mode=True,
                connect_timeout=3,
                log_level='ERROR',
            ),
            "-i '~/.ssh/id_ed25519' -o BatchMode=yes -o LogLevel=ERROR "
            '-o ConnectTimeout=3',
        )

    def test_flags_and_lists(self):
        opts = ssh.build_options(
            configfile='/etc/ssh/ssh_config',
            identity=['/a', '/b'],
            ssh_option=['StrictHostKeyChecking=no'],
            ipv4=True,
            quiet=True,
        )
        self.assertIn('-4', opts)
        self.assertIn("-F '/etc/ssh/ssh_config'", opts)
        self.assertIn("-i '/a'", opts)
        self.assertIn("-i '/b'", opts)
        self.assertIn("-o 'StrictHostKeyChecking=no'", opts)
        self.assertIn('-q', opts)


class TestTarget(unittest.TestCase):
    def test_without_username(self):
        self.assertEqual(ssh.target('myhost'), "'myhost'")

    def test_with_username(self):
        self.assertEqual(ssh.target('myhost', 'root'), "'root'@'myhost'")


class TestRun(unittest.TestCase):
    def _capture(self):
        captured = {}

        def fake(cmd, shell=False, timeout=None):
            captured['cmd'] = cmd
            captured['shell'] = shell
            captured['timeout'] = timeout
            return (True, ('out', '', 0))

        return captured, fake

    def test_builds_ssh_command(self):
        captured, fake = self._capture()
        with mock.patch('lib.ssh.shell.shell_exec', side_effect=fake):
            ok, result = ssh.run(
                'myhost', 'true', username='root', port=2222, options='-q'
            )
        self.assertTrue(ok)
        self.assertEqual(result, ('out', '', 0))
        self.assertEqual(captured['cmd'], "ssh -q -p 2222 'root'@'myhost' 'true'")
        self.assertTrue(captured['shell'])

    def test_password_prefixes_sshpass(self):
        captured, fake = self._capture()
        with mock.patch('lib.ssh.shell.shell_exec', side_effect=fake):
            ssh.run('myhost', 'true', password='linuxfabrik')
        self.assertTrue(captured['cmd'].startswith('sshpass -p linuxfabrik ssh '))


class TestScp(unittest.TestCase):
    def test_recursive_adds_flags(self):
        captured = {}
        with mock.patch(
            'lib.ssh.shell.shell_exec',
            side_effect=lambda cmd, shell=False, timeout=None: captured.update(cmd=cmd)
            or (True, ('', '', 0)),
        ):
            ssh.scp('myhost', '/local/dir', '/remote/dir', recursive=True)
        self.assertIn('scp -r -p', captured['cmd'])
        self.assertIn("'/local/dir' 'myhost':/remote/dir", captured['cmd'])


class TestRsync(unittest.TestCase):
    def test_archive_rsh_and_sudo(self):
        captured = {}
        with mock.patch(
            'lib.ssh.shell.shell_exec',
            side_effect=lambda cmd, shell=False, timeout=None: captured.update(cmd=cmd)
            or (True, ('', '', 0)),
        ):
            ssh.rsync(
                'myhost', '/local/dir', '/remote/dir', options='-q', sudo=True
            )
        cmd = captured['cmd']
        self.assertIn('rsync --archive', cmd)
        self.assertIn("--rsync-path='sudo rsync'", cmd)
        self.assertIn('--rsh="ssh -q"', cmd)
        self.assertIn("'/local/dir/' 'myhost':/remote/dir/", cmd)

    def test_no_sudo_omits_rsync_path(self):
        captured = {}
        with mock.patch(
            'lib.ssh.shell.shell_exec',
            side_effect=lambda cmd, shell=False, timeout=None: captured.update(cmd=cmd)
            or (True, ('', '', 0)),
        ):
            ssh.rsync('myhost', '/local/dir', '/remote/dir')
        self.assertNotIn('--rsync-path', captured['cmd'])


if __name__ == '__main__':
    unittest.main()
