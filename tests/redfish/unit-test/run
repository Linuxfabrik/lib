            redfish.get_systems_storage(body),
            {
                'Description': 'RAID Storage',
                'Drives@odata.count': 5,
                'Id': '6789',
                'Name': 'StorageSystem1',
                'Volumes_@odata.id': '',
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
                'Status_HealthRollup': 'OK',
            },
        )

    def test_empty(self):
        out = redfish.get_systems_storage({})
        for key in redfish.SYSTEMS_STORAGE_KEYS:
            self.assertEqual(out[key], '')
        for key in redfish.SYSTEMS_STORAGE_NESTED_KEYS:
            self.assertEqual(out[key], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems_storage({})
        expected = set(redfish.SYSTEMS_STORAGE_KEYS) | set(
            redfish.SYSTEMS_STORAGE_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_systems_storage_drives (CapacityBytes humanizing)
# ---------------------------------------------------------------------------
class TestGetSystemsStorageDrives(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_systems_storage_drives(load(DRIVE_BODY))
        self.assertEqual(out['BlockSizeBytes'], 512)
        self.assertEqual(out['CapableSpeedGbs'], 12)
        self.assertEqual(out['Description'], 'Disk Drive Bay 0')
        self.assertEqual(out['MediaType'], 'SSD')
        self.assertEqual(out['Model'], '970 EVO')
        self.assertEqual(out['Protocol'], 'NVMe')
        self.assertEqual(out['SerialNumber'], 'S1234NEAB00001')
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')
        self.assertEqual(out['Status_HealthRollup'], 'OK')
        # CapacityBytes is humanized via lib.human.bytes2human.
        self.assertEqual(out['CapacityBytes'], CAP_500GB)

    def test_capacity_matches_human_helper(self):
        out = redfish.get_systems_storage_drives({'CapacityBytes': 500000000000})
        self.assertEqual(out['CapacityBytes'], human.bytes2human(500000000000))

    def test_capacity_missing_is_empty(self):
        out = redfish.get_systems_storage_drives({})
        self.assertEqual(out['CapacityBytes'], '')

    def test_capacity_zero_is_empty(self):
        # `if capacity` is falsy for 0 -> '' rather than bytes2human(0).
        out = redfish.get_systems_storage_drives({'CapacityBytes': 0})
        self.assertEqual(out['CapacityBytes'], '')

    def test_failure_predicted_false_preserved(self):
        out = redfish.get_systems_storage_drives({'FailurePredicted': False})
        self.assertEqual(out['FailurePredicted'], False)

    def test_temperature_from_current_temperature_celsius(self):
        # vendor quirk: HPE SmartStorage exposes CurrentTemperatureCelsius
        out = redfish.get_systems_storage_drives({'CurrentTemperatureCelsius': 37})
        self.assertEqual(out['Temperature'], 37)

    def test_temperature_from_oem_temperature_celsius(self):
        out = redfish.get_systems_storage_drives(
            {'Oem': {'Hpe': {'TemperatureCelsius': 41}}}
        )
        self.assertEqual(out['Temperature'], 41)

    def test_temperature_from_oem_temperature_c(self):
        out = redfish.get_systems_storage_drives({'Oem': {'Dell': {'TemperatureC': 29}}})
        self.assertEqual(out['Temperature'], 29)

    def test_temperature_missing_is_empty(self):
        out = redfish.get_systems_storage_drives({})
        self.assertEqual(out['Temperature'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems_storage_drives({})
        # CapacityBytes and Temperature are added on top of the flat + nested key
        # sets.
        expected = (
            set(redfish.SYSTEMS_STORAGE_DRIVES_KEYS)
            | set(redfish.SYSTEMS_STORAGE_DRIVES_NESTED_KEYS)
            | {'CapacityBytes', 'Temperature'}
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_vendor
# ---------------------------------------------------------------------------
class TestGetVendor(unittest.TestCase):
    def test_explicit_vendor_lowercased(self):
        self.assertEqual(redfish.get_vendor({'Vendor': 'DELL'}), 'dell')

    def test_oem_first_key_used(self):
        self.assertEqual(redfish.get_vendor({'Oem': {'SomeVendor': 'x'}}), 'somevendor')

    def test_empty_dict_is_generic(self):
        self.assertEqual(redfish.get_vendor({}), 'generic')

    def test_empty_oem_is_generic(self):
        self.assertEqual(redfish.get_vendor({'Oem': {}}), 'generic')

    def test_vendor_none_falls_back_to_oem(self):
        self.assertEqual(redfish.get_vendor({'Vendor': None, 'Oem': {'Hpe': 1}}), 'hpe')

    def test_vendor_empty_string_falls_back_to_oem(self):
        self.assertEqual(
            redfish.get_vendor({'Vendor': '', 'Oem': {'Lenovo': 1}}), 'lenovo'
        )

    def test_oem_none_is_generic(self):
        # `redfish.get('Oem') or {}` guards an explicit None Oem.
        self.assertEqual(redfish.get_vendor({'Oem': None}), 'generic')

    def test_vendor_wins_over_oem(self):
        self.assertEqual(
            redfish.get_vendor({'Vendor': 'Dell', 'Oem': {'Hpe': 1}}), 'dell'
        )


if __name__ == '__main__':
    unittest.main()
