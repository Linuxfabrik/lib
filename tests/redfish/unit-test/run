"""Unit tests for lib.redfish.

lib.redfish is a pure parser: it never opens a socket itself. The plugins that
use it do the HTTP talking (through lib.url) and hand the already-decoded JSON
(a Python dict) to these functions. There is therefore no transport to mock for
the module's own behaviour; the "HTTP layer" is the caller's concern. To keep
the suite honest about that contract, the request-side is still asserted: a
representative captured-style Redfish payload is decoded exactly the way a
plugin would (json.loads on a fetched body) and fed in, and the parser output
is pinned byte for byte.

Public functions under test (16):

- get_chassis()                            -> flat + nested key projection
- get_chassis_power_powercontrol()         -> projection
- get_chassis_power_powersupplies()        -> projection + PowerOutputWatts fallback
- get_chassis_power_voltages()             -> projection
- get_chassis_sensors()                    -> projection with 3-level threshold paths
- get_chassis_thermal_fans()               -> projection + RPM/percent quirk
- get_chassis_thermal_redundancy()         -> projection
- get_chassis_thermal_temperatures()       -> projection
- get_manager_logservices_sel_entries()    -> SEL formatting + worst-state rollup
- get_perfdata()                           -> Nagios perfdata builder
- get_sensor_state()                       -> state by status/health/thresholds/range
- get_state()                              -> state by status/health
- get_systems()                            -> projection
- get_systems_memory()                     -> projection + CapacityMiB + vendor quirks
- get_systems_storage()                    -> projection
- get_systems_storage_drives()             -> projection + CapacityBytes + temperature
- get_vendor()                             -> Vendor / Oem / 'generic' resolution

All expected values were probed against the live module first, then pinned.
Notably: lib.base.state2str renders [CRITICAL]/[WARNING] (not [CRIT]/[WARN]),
lib.human.bytes2human uses binary units (465.7GiB for 5e11), a falsy-but-valid
LastPowerOutputWatts of 0 does NOT trigger the PowerOutputWatts fallback, and
ReadingRangeMin/Max of 0 are dropped from perfdata because of the `or None`.
"""

import json
import re
import sys
import typing
import unittest

sys.path.insert(0, '..')

import lib.base as base
import lib.human as human
import lib.redfish as redfish
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

# ---------------------------------------------------------------------------
# Captured-style Redfish payloads. These are decoded exactly the way a plugin
# would after lib.url fetched the body, to assert the parser against realistic,
# vendor-shaped JSON rather than hand-rolled minimal dicts.
# ---------------------------------------------------------------------------

CHASSIS_BODY = """
{
    "@odata.id": "/redfish/v1/Chassis/1",
    "AssetTag": "LF-ASSET-001",
    "ChassisType": "RackMount",
    "Id": "1",
    "IndicatorLED": "Off",
    "Manufacturer": "Dell Inc.",
    "Model": "PowerEdge R750",
    "PartNumber": "0ABCDE",
    "PowerState": "On",
    "SerialNumber": "SN1234567",
    "SKU": "SKU-9000",
    "Sensors": {"@odata.id": "/redfish/v1/Chassis/1/Sensors"},
    "Status": {"State": "Enabled", "Health": "OK", "HealthRollup": "OK"}
}
"""

SENSOR_BODY = """
{
    "Id": "TempCPU1",
    "Name": "CPU 1 Temp",
    "PhysicalContext": "CPU",
    "Reading": 55.0,
    "ReadingRangeMax": 120,
    "ReadingRangeMin": 0,
    "ReadingUnits": "Cel",
    "Thresholds": {
        "LowerCaution": {"Reading": 5},
        "LowerCritical": {"Reading": 0},
        "UpperCaution": {"Reading": 90},
        "UpperCritical": {"Reading": 105}
    },
    "Status": {"State": "Enabled", "Health": "OK", "HealthRollup": "OK"}
}
"""

DRIVE_BODY = """
{
    "BlockSizeBytes": 512,
    "CapableSpeedGbs": 12,
    "CapacityBytes": 500000000000,
    "Description": "Disk Drive Bay 0",
    "EncryptionAbility": "SelfEncryptingDrive",
    "EncryptionStatus": "Unlocked",
    "FailurePredicted": false,
    "HotspareType": "None",
    "Id": "Disk.Bay.0",
    "Manufacturer": "Samsung",
    "MediaType": "SSD",
    "Model": "970 EVO",
    "Name": "SSD 0",
    "NegotiatedSpeedGbs": 12,
    "PartNumber": "PN-001",
    "PredictedMediaLifeLeftPercent": 98,
    "Protocol": "NVMe",
    "Revision": "1B2QEXM7",
    "RotationSpeedRPM": 0,
    "SerialNumber": "S1234NEAB00001",
    "WriteCacheEnabled": true,
    "Status": {"State": "Enabled", "Health": "OK", "HealthRollup": "OK"}
}
"""


def load(body):
    """Decode a captured body the way a plugin does after lib.url fetched it."""
    return json.loads(body)


# ---------------------------------------------------------------------------
# Shared expectations derived from the dependencies (probed, then pinned), so a
# change in base/human surfaces here instead of silently passing.
# ---------------------------------------------------------------------------

CRIT_SUFFIX = base.state2str(STATE_CRIT, prefix=' ')  # ' [CRITICAL]'
WARN_SUFFIX = base.state2str(STATE_WARN, prefix=' ')  # ' [WARNING]'
CAP_500GB = human.bytes2human(500000000000)  # '465.7GiB'


# ---------------------------------------------------------------------------
# get_chassis
# ---------------------------------------------------------------------------
class TestGetChassis(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_chassis(load(CHASSIS_BODY))
        self.assertEqual(
            out,
            {
                'AssetTag': 'LF-ASSET-001',
                'ChassisType': 'RackMount',
                'Id': '1',
                'IndicatorLED': 'Off',
                'Manufacturer': 'Dell Inc.',
                'Model': 'PowerEdge R750',
                'PartNumber': '0ABCDE',
                'PowerState': 'On',
                'SerialNumber': 'SN1234567',
                'SKU': 'SKU-9000',
                'Sensors_@odata.id': '/redfish/v1/Chassis/1/Sensors',
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
                'Status_HealthRollup': 'OK',
            },
        )

    def test_empty_dict_all_blank(self):
        out = redfish.get_chassis({})
        # every flat key present and '' ...
        for key in redfish.CHASSIS_KEYS:
            self.assertEqual(out[key], '')
        # ... and every nested key present and ''
        for key in redfish.CHASSIS_NESTED_KEYS:
            self.assertEqual(out[key], '')

    def test_missing_status_subtree(self):
        out = redfish.get_chassis({'Id': '7'})
        self.assertEqual(out['Id'], '7')
        self.assertEqual(out['Status_State'], '')
        self.assertEqual(out['Status_Health'], '')
        self.assertEqual(out['Status_HealthRollup'], '')
        self.assertEqual(out['Sensors_@odata.id'], '')

    def test_partial_nested_status(self):
        out = redfish.get_chassis({'Status': {'Health': 'Warning'}})
        self.assertEqual(out['Status_Health'], 'Warning')
        self.assertEqual(out['Status_State'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis({})
        expected = set(redfish.CHASSIS_KEYS) | set(redfish.CHASSIS_NESTED_KEYS)
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_power_powercontrol
# ---------------------------------------------------------------------------
class TestGetChassisPowerPowercontrol(unittest.TestCase):
    def test_full_projection(self):
        out = redfish.get_chassis_power_powercontrol(
            {
                'MemberId': '0',
                'Name': 'System Power Control',
                'PowerCapacityWatts': 800,
                'PowerConsumedWatts': 344,
                'Status': {'State': 'Enabled', 'Health': 'OK'},
            }
        )
        self.assertEqual(
            out,
            {
                'MemberId': '0',
                'Name': 'System Power Control',
                'PowerCapacityWatts': 800,
                'PowerConsumedWatts': 344,
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
            },
        )

    def test_empty(self):
        out = redfish.get_chassis_power_powercontrol({})
        for value in out.values():
            self.assertEqual(value, '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_power_powercontrol({})
        expected = set(redfish.CHASSIS_POWER_CONTROL_KEYS) | set(
            redfish.CHASSIS_POWER_CONTROL_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_power_powersupplies
# ---------------------------------------------------------------------------
class TestGetChassisPowerPowersupplies(unittest.TestCase):
    def test_full_projection(self):
        body = {
            'FirmwareVersion': '1.0',
            'LastPowerOutputWatts': 200,
            'LineInputVoltage': 230,
            'LineInputVoltageType': 'ACHighLine',
            'Manufacturer': 'Dell',
            'Model': 'PSU-750',
            'PartNumber': 'PN9',
            'PowerCapacityWatts': 750,
            'PowerSupplyType': 'AC',
            'SerialNumber': 'PSU-SN',
            'SparePartNumber': 'SPN9',
            'Status': {'State': 'Enabled', 'Health': 'OK'},
        }
        out = redfish.get_chassis_power_powersupplies(body)
        self.assertEqual(out['LastPowerOutputWatts'], 200)
        self.assertEqual(out['PowerCapacityWatts'], 750)
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_fallback_to_power_output_watts_when_missing(self):
        out = redfish.get_chassis_power_powersupplies({'PowerOutputWatts': 123})
        self.assertEqual(out['LastPowerOutputWatts'], 123)

    def test_fallback_to_power_output_watts_when_empty_string(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': '', 'PowerOutputWatts': 321}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 321)

    def test_fallback_to_power_output_watts_when_none(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': None, 'PowerOutputWatts': 50}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 50)

    def test_direct_value_wins_over_fallback(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': 99, 'PowerOutputWatts': 123}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 99)

    def test_zero_is_valid_and_does_not_trigger_fallback(self):
        # 0 is not in ('', None), so the fallback must not kick in.
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': 0, 'PowerOutputWatts': 123}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 0)

    def test_no_watts_at_all_stays_empty(self):
        out = redfish.get_chassis_power_powersupplies({})
        self.assertEqual(out['LastPowerOutputWatts'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_power_powersupplies({})
        expected = set(redfish.CHASSIS_POWER_KEYS) | set(
            redfish.CHASSIS_POWER_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


