            {
                'Mode': 'N+1',
                'Name': 'Fan Redundancy',
                'Status': {'State': 'Enabled', 'Health': 'OK'},
            }
        )
        self.assertEqual(
            out,
            {
                'Mode': 'N+1',
                'Name': 'Fan Redundancy',
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
            },
        )

    def test_partial(self):
        out = redfish.get_chassis_thermal_redundancy(
            {'Mode': 'N+1', 'Status': {'Health': 'OK'}}
        )
        self.assertEqual(
            out, {'Mode': 'N+1', 'Name': '', 'Status_State': '', 'Status_Health': 'OK'}
        )

    def test_empty(self):
        out = redfish.get_chassis_thermal_redundancy({})
        self.assertEqual(
            out, {'Mode': '', 'Name': '', 'Status_State': '', 'Status_Health': ''}
        )


