            redfish.CHASSIS_VOLTAGE_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_sensors (3-level nested threshold paths + isinstance filter)
# ---------------------------------------------------------------------------
class TestGetChassisSensors(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_chassis_sensors(load(SENSOR_BODY))
        self.assertEqual(out['Id'], 'TempCPU1')
        self.assertEqual(out['Name'], 'CPU 1 Temp')
        self.assertEqual(out['PhysicalContext'], 'CPU')
        self.assertEqual(out['Reading'], 55.0)
        self.assertEqual(out['ReadingRangeMax'], 120)
        self.assertEqual(out['ReadingRangeMin'], 0)
        self.assertEqual(out['ReadingUnits'], 'Cel')
        # 3-level paths: Thresholds.<x>.Reading
        self.assertEqual(out['Thresholds_LowerCaution'], 5)
        self.assertEqual(out['Thresholds_LowerCritical'], 0)
        self.assertEqual(out['Thresholds_UpperCaution'], 90)
        self.assertEqual(out['Thresholds_UpperCritical'], 105)
        # absent user thresholds collapse to ''
        self.assertEqual(out['Thresholds_LowerCautionUser'], '')
        self.assertEqual(out['Thresholds_UpperCriticalUser'], '')
        self.assertEqual(out['Status_State'], 'Enabled')

    def test_missing_thresholds_subtree(self):
        out = redfish.get_chassis_sensors({'Id': 's', 'Reading': 1})
        for key in (
            'Thresholds_LowerCaution',
            'Thresholds_LowerCritical',
            'Thresholds_UpperCaution',
            'Thresholds_UpperCritical',
        ):
            self.assertEqual(out[key], '')

    def test_non_scalar_reading_is_filtered_to_empty(self):
        # A dict at the leaf must be replaced by '' (isinstance scalar filter).
        body = {'Thresholds': {'LowerCaution': {'Reading': {'nested': 1}}}}
        out = redfish.get_chassis_sensors(body)
        self.assertEqual(out['Thresholds_LowerCaution'], '')

    def test_string_scalar_passes_filter(self):
        body = {'Thresholds': {'UpperCritical': {'Reading': '105'}}}
        out = redfish.get_chassis_sensors(body)
        self.assertEqual(out['Thresholds_UpperCritical'], '105')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_sensors({})
        expected = set(redfish.CHASSIS_SENSOR_KEYS) | set(
            redfish.CHASSIS_SENSOR_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_thermal_fans
# ---------------------------------------------------------------------------
class TestGetChassisThermalFans(unittest.TestCase):
    def test_full_projection(self):
        body = {
            'FanName': 'Fan1',
            'HotPluggable': True,
            'LowerThresholdCritical': 100,
            'LowerThresholdFatal': 50,
            'LowerThresholdNonCritical': 200,
            'Name': 'System Fan 1',
            'PhysicalContext': 'Fan',
            'Reading': 8000,
            'ReadingUnits': 'RPM',
            'SensorNumber': 1,
            'UpperThresholdCritical': 20000,
            'UpperThresholdFatal': 22000,
            'UpperThresholdNonCritical': 18000,
            'Status': {'State': 'Enabled', 'Health': 'OK'},
        }
        out = redfish.get_chassis_thermal_fans(body)
        self.assertEqual(out['FanName'], 'Fan1')
        self.assertEqual(out['Reading'], 8000)
        self.assertEqual(out['ReadingUnits'], 'RPM')
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_non_scalar_status_state_filtered(self):
        out = redfish.get_chassis_thermal_fans({'Status': {'State': {'x': 1}}})
        self.assertEqual(out['Status_State'], '')

    def test_reading_rpm_field_used(self):
        # vendor quirk: Dell/Fujitsu/Huawei report speed under ReadingRPM
        out = redfish.get_chassis_thermal_fans({'ReadingRPM': 9000})
        self.assertEqual(out['Reading'], 9000)
        self.assertEqual(out['ReadingUnits'], 'RPM')

    def test_reading_rpm_field_wins_over_reading(self):
        out = redfish.get_chassis_thermal_fans({'ReadingRPM': 9000, 'Reading': 10})
        self.assertEqual(out['Reading'], 9000)
        self.assertEqual(out['ReadingUnits'], 'RPM')

    def test_reading_units_rpm_keeps_reading(self):
        # ReadingUnits == 'RPM' but the value sits in Reading (no ReadingRPM)
        out = redfish.get_chassis_thermal_fans({'Reading': 7000, 'ReadingUnits': 'RPM'})
        self.assertEqual(out['Reading'], 7000)
        self.assertEqual(out['ReadingUnits'], 'RPM')

    def test_percent_unit_mapped_to_symbol(self):
        # HP/Lenovo report a percentage; 'Percent' is normalized to '%'
        out = redfish.get_chassis_thermal_fans(
            {'Reading': 42, 'ReadingUnits': 'Percent'}
        )
        self.assertEqual(out['Reading'], 42)
        self.assertEqual(out['ReadingUnits'], '%')

    def test_empty(self):
        out = redfish.get_chassis_thermal_fans({})
        self.assertEqual(out['FanName'], '')
        self.assertEqual(out['Status_Health'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_thermal_fans({})
        expected = set(redfish.CHASSIS_FAN_KEYS) | set(redfish.CHASSIS_FAN_NESTED_KEYS)
        self.assertEqual(set(out), expected)


