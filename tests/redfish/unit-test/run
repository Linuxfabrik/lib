def load(body):
    """Decode a captured body the way a plugin does after lib.url fetched it."""
    return json.loads(body)


# ---------------------------------------------------------------------------
# Shared expectations derived from the dependencies (probed, then pinned), so a
# change in base/human surfaces here instead of silently passing.
# ---------------------------------------------------------------------------

CRIT_SUFFIX = base.state2str(STATE_CRIT, prefix=' ')  # ' [CRITICAL]'
WARN_SUFFIX = base.state2str(STATE_WARN, prefix=' ')  # ' [WARNING]'
CAP_500GB = human.bytes2human(500000000000)  # '465.7GiB'


# ---------------------------------------------------------------------------
# get_auth_header (create a session, return header + token + ttl; lib.url mocked)
# ---------------------------------------------------------------------------
# a session creation response as lib.url returns it with extended=True: the
# X-Auth-Token header, lower-cased by lib.url (RFC 9110, section 5.1).
SESSION_CREATED = (True, {'response_header': {'x-auth-token': 'new-token'}})


def _args(**over):
    """Build a minimal args namespace with sane, RFC-5737 defaults."""
    values = {
        'CACHE_EXPIRE': 60,  # minutes
        'INSECURE': True,
        'NO_PROXY': False,
        'PASSWORD': 'linuxfabrik',
        'TIMEOUT': 8,
        'URL': 'https://203.0.113.10',
        'USERNAME': 'linuxfabrik',
    }
    values.update(over)
    return types.SimpleNamespace(**values)


TOKEN_KEY = 'redfish-https://203.0.113.10-linuxfabrik-token'


class TestGetAuthHeader(unittest.TestCase):
    def test_no_credentials_returns_empty_header(self):
        # Without both username and password there is nothing to authenticate.
        self.assertEqual(redfish.get_auth_header(_args(USERNAME='', PASSWORD='')), {})
        self.assertEqual(redfish.get_auth_header(_args(PASSWORD='')), {})

    @mock.patch.object(redfish, 'url')
    def test_uncached_session_returns_token_header_without_probing_timeout(self, url_mock):
        # cache_expire=0 (default): create a session, return its token header, and
        # do NOT probe the SessionService (there is no lifetime to bound).
        url_mock.fetch_json.side_effect = [SESSION_CREATED]
        header = redfish.get_auth_header(_args())
        self.assertEqual(header, {'X-Auth-Token': 'new-token'})
        self.assertEqual(url_mock.fetch_json.call_count, 1)

    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cached_token_short_circuits(self, url_mock, cache_mock):
        # A cached token is returned as-is; no session is created.
        cache_mock.get.return_value = 'cached-token'
        header = redfish.get_auth_header(_args(), cache_expire=300)
        self.assertEqual(header, {'X-Auth-Token': 'cached-token'})
        url_mock.fetch_json.assert_not_called()
        cache_mock.set.assert_not_called()

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_caching_bounds_ttl_with_session_timeout_margin(
        self, url_mock, cache_mock, time_mock
    ):
        cache_mock.get.return_value = False  # cache miss
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (True, {'SessionTimeout': 300})]
        header = redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=3600)
        self.assertEqual(header, {'X-Auth-Token': 'new-token'})
        # min(3600, 300 - 8) = 292, cached until now + 292
        cache_mock.set.assert_called_once_with(
            TOKEN_KEY, 'new-token', 1000 + 292, filename=redfish.CACHE_FILENAME
        )

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cache_expire_caps_a_large_session_timeout(self, url_mock, cache_mock, time_mock):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (True, {'SessionTimeout': 86400})]
        redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=60)
        # min(60, 86400 - 8) = 60
        self.assertEqual(cache_mock.set.call_args[0][2], 1000 + 60)

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_string_session_timeout_is_coerced(self, url_mock, cache_mock, time_mock):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (True, {'SessionTimeout': '300'})]
        redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=3600)
        self.assertEqual(cache_mock.set.call_args[0][2], 1000 + 292)

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_margin_never_drops_below_one_second(self, url_mock, cache_mock, time_mock):
        # SessionTimeout below the margin would go negative; clamped to 1.
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (True, {'SessionTimeout': 5})]
        redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=3600)
        self.assertEqual(cache_mock.set.call_args[0][2], 1000 + 1)

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_missing_session_timeout_falls_back_to_cache_expire(
        self, url_mock, cache_mock, time_mock
    ):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (True, {'Id': 'default'})]
        redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=120)
        # only cache_expire applies: 120
        self.assertEqual(cache_mock.set.call_args[0][2], 1000 + 120)

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_sessionservice_get_failure_falls_back_to_cache_expire(
        self, url_mock, cache_mock, time_mock
    ):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.side_effect = [SESSION_CREATED, (False, 'Bad Gateway')]
        redfish.get_auth_header(_args(TIMEOUT=8), cache_expire=180)
        self.assertEqual(cache_mock.set.call_args[0][2], 1000 + 180)

    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_session_creation_failure_falls_back_to_basic_auth(self, url_mock, cache_mock):
        # No X-Auth-Token in the response header -> no session token.
        cache_mock.get.return_value = False
        url_mock.fetch_json.side_effect = [(False, 'Unauthorized')]
        header = redfish.get_auth_header(_args(), cache_expire=300)
        # 'linuxfabrik:linuxfabrik' base64-encoded.
        self.assertEqual(header, {'Authorization': 'Basic bGludXhmYWJyaWs6bGludXhmYWJyaWs='})
        # nothing is cached on the Basic-auth fallback
        cache_mock.set.assert_not_called()
        # Only the session-creation POST was attempted; no SessionService GET.
        self.assertEqual(url_mock.fetch_json.call_count, 1)

    @mock.patch.object(redfish, 'url')
    def test_non_dict_session_response_falls_back_to_basic_auth(self, url_mock):
        # success but body is not a dict -> the isinstance guard rejects it.
        url_mock.fetch_json.side_effect = [(True, 'not-a-dict')]
        header = redfish.get_auth_header(_args())
        self.assertEqual(header, {'Authorization': 'Basic bGludXhmYWJyaWs6bGludXhmYWJyaWs='})


# ---------------------------------------------------------------------------
# get_chassis
# ---------------------------------------------------------------------------
class TestGetChassis(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_chassis(load(CHASSIS_BODY))
        self.assertEqual(
            out,
            {
                'AssetTag': 'LF-ASSET-001',
                'ChassisType': 'RackMount',
                'Id': '1',
                'IndicatorLED': 'Off',
                'Manufacturer': 'Dell Inc.',
                'Model': 'PowerEdge R750',
                'PartNumber': '0ABCDE',
                'PowerState': 'On',
                'SerialNumber': 'SN1234567',
                'SKU': 'SKU-9000',
                'Sensors_@odata.id': '/redfish/v1/Chassis/1/Sensors',
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
                'Status_HealthRollup': 'OK',
            },
        )

    def test_empty_dict_all_blank(self):
        out = redfish.get_chassis({})
        # every flat key present and '' ...
        for key in redfish.CHASSIS_KEYS:
            self.assertEqual(out[key], '')
        # ... and every nested key present and ''
        for key in redfish.CHASSIS_NESTED_KEYS:
            self.assertEqual(out[key], '')

    def test_missing_status_subtree(self):
        out = redfish.get_chassis({'Id': '7'})
        self.assertEqual(out['Id'], '7')
        self.assertEqual(out['Status_State'], '')
        self.assertEqual(out['Status_Health'], '')
        self.assertEqual(out['Status_HealthRollup'], '')
        self.assertEqual(out['Sensors_@odata.id'], '')

    def test_partial_nested_status(self):
        out = redfish.get_chassis({'Status': {'Health': 'Warning'}})
        self.assertEqual(out['Status_Health'], 'Warning')
        self.assertEqual(out['Status_State'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis({})
        expected = set(redfish.CHASSIS_KEYS) | set(redfish.CHASSIS_NESTED_KEYS)
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_power_powercontrol
# ---------------------------------------------------------------------------
class TestGetChassisPowerPowercontrol(unittest.TestCase):
    def test_full_projection(self):
        out = redfish.get_chassis_power_powercontrol(
            {
                'MemberId': '0',
                'Name': 'System Power Control',
                'PowerCapacityWatts': 800,
                'PowerConsumedWatts': 344,
                'Status': {'State': 'Enabled', 'Health': 'OK'},
            }
        )
        self.assertEqual(
            out,
            {
                'MemberId': '0',
                'Name': 'System Power Control',
                'PowerCapacityWatts': 800,
                'PowerConsumedWatts': 344,
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
            },
        )

    def test_empty(self):
        out = redfish.get_chassis_power_powercontrol({})
        for value in out.values():
            self.assertEqual(value, '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_power_powercontrol({})
        expected = set(redfish.CHASSIS_POWER_CONTROL_KEYS) | set(
            redfish.CHASSIS_POWER_CONTROL_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_chassis_power_powersupplies
# ---------------------------------------------------------------------------
class TestGetChassisPowerPowersupplies(unittest.TestCase):
    def test_full_projection(self):
        body = {
            'FirmwareVersion': '1.0',
            'LastPowerOutputWatts': 200,
            'LineInputVoltage': 230,
            'LineInputVoltageType': 'ACHighLine',
            'Manufacturer': 'Dell',
            'Model': 'PSU-750',
            'PartNumber': 'PN9',
            'PowerCapacityWatts': 750,
            'PowerSupplyType': 'AC',
            'SerialNumber': 'PSU-SN',
            'SparePartNumber': 'SPN9',
            'Status': {'State': 'Enabled', 'Health': 'OK'},
        }
        out = redfish.get_chassis_power_powersupplies(body)
        self.assertEqual(out['LastPowerOutputWatts'], 200)
        self.assertEqual(out['PowerCapacityWatts'], 750)
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_fallback_to_power_output_watts_when_missing(self):
        out = redfish.get_chassis_power_powersupplies({'PowerOutputWatts': 123})
        self.assertEqual(out['LastPowerOutputWatts'], 123)

    def test_fallback_to_power_output_watts_when_empty_string(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': '', 'PowerOutputWatts': 321}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 321)

    def test_fallback_to_power_output_watts_when_none(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': None, 'PowerOutputWatts': 50}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 50)

    def test_direct_value_wins_over_fallback(self):
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': 99, 'PowerOutputWatts': 123}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 99)

    def test_zero_is_valid_and_does_not_trigger_fallback(self):
        # 0 is not in ('', None), so the fallback must not kick in.
        out = redfish.get_chassis_power_powersupplies(
            {'LastPowerOutputWatts': 0, 'PowerOutputWatts': 123}
        )
        self.assertEqual(out['LastPowerOutputWatts'], 0)

    def test_no_watts_at_all_stays_empty(self):
        out = redfish.get_chassis_power_powersupplies({})
        self.assertEqual(out['LastPowerOutputWatts'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_chassis_power_powersupplies({})
        expected = set(redfish.CHASSIS_POWER_KEYS) | set(
            redfish.CHASSIS_POWER_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


