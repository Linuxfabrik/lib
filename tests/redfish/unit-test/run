            redfish.CHASSIS_THERMAL_TEMP_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_manager_logservices_sel_entries
# ---------------------------------------------------------------------------
# entries dated 2021, shared by the SEL filter/aging tests below
SEL_MIXED_BODY = {
    'Members': [
        {'Created': '2021-08-01', 'Message': 'Temp high', 'Severity': 'Critical'},
        {'Created': '2021-08-02', 'Message': 'Fan normal', 'Severity': 'OK'},
        {'Created': '2021-08-03', 'Message': 'warn msg', 'Severity': 'Warning'},
    ]
}


class TestGetManagerLogservicesSelEntries(unittest.TestCase):
    def test_mixed_severities_worst_state_and_format(self):
        msg, state, aged = redfish.get_manager_logservices_sel_entries(SEL_MIXED_BODY)
        self.assertEqual(state, STATE_CRIT)
        self.assertEqual(aged, 0)
        self.assertEqual(
            msg,
            f'* 2021-08-01: Temp high{CRIT_SUFFIX}\n* 2021-08-03: warn msg{WARN_SUFFIX}\n',
        )

    def test_ok_entries_are_skipped(self):
        body = {'Members': [{'Created': 'x', 'Message': 'm', 'Severity': 'OK'}]}
        self.assertEqual(
            redfish.get_manager_logservices_sel_entries(body), ('', STATE_OK, 0)
        )

    def test_empty_members(self):
        self.assertEqual(
            redfish.get_manager_logservices_sel_entries({'Members': []}),
            ('', STATE_OK, 0),
        )

    def test_missing_members_key(self):
        self.assertEqual(
            redfish.get_manager_logservices_sel_entries({}), ('', STATE_OK, 0)
        )

    def test_unknown_severity_maps_to_ok_no_suffix(self):
        # Unknown severity -> STATE_OK -> no '[...]' suffix, no state escalation.
        body = {
            'Members': [
                {'Created': '2021-08-04', 'Message': 'odd', 'Severity': 'Strange'}
            ]
        }
        msg, state, _ = redfish.get_manager_logservices_sel_entries(body)
        self.assertEqual(msg, '* 2021-08-04: odd\n')
        self.assertEqual(state, STATE_OK)

    def test_warning_only_state_is_warn(self):
        body = {'Members': [{'Created': 'c', 'Message': 'm', 'Severity': 'Warning'}]}
        msg, state, _ = redfish.get_manager_logservices_sel_entries(body)
        self.assertEqual(state, STATE_WARN)
        self.assertEqual(msg, f'* c: m{WARN_SUFFIX}\n')

    def test_severity_is_case_insensitive(self):
        body = {'Members': [{'Created': 'c', 'Message': 'm', 'Severity': 'CRITICAL'}]}
        _, state, _ = redfish.get_manager_logservices_sel_entries(body)
        self.assertEqual(state, STATE_CRIT)

    def test_missing_fields_default_to_empty(self):
        body = {'Members': [{'Severity': 'Warning'}]}
        msg, state, _ = redfish.get_manager_logservices_sel_entries(body)
        self.assertEqual(msg, f'* : {WARN_SUFFIX}\n')
        self.assertEqual(state, STATE_WARN)

    def test_missing_severity_treated_as_ok(self):
        # entry.get('Severity', '').lower() -> '' -> mapped to STATE_OK, but '' != 'ok'
        # so it is NOT skipped; it is emitted with no suffix.
        body = {'Members': [{'Created': 'c', 'Message': 'm'}]}
        msg, state, _ = redfish.get_manager_logservices_sel_entries(body)
        self.assertEqual(msg, '* c: m\n')
        self.assertEqual(state, STATE_OK)

    def test_ignore_drops_matching_message(self):
        # --ignore drops the critical 'Temp high' entry, leaving the warning.
        ignore = [re.compile('Temp')]
        msg, state, aged = redfish.get_manager_logservices_sel_entries(
            SEL_MIXED_BODY, ignore=ignore
        )
        self.assertEqual(state, STATE_WARN)
        self.assertEqual(aged, 0)
        self.assertNotIn('Temp high', msg)
        self.assertIn('warn msg', msg)

    def test_match_keeps_only_matching_message(self):
        # --match keeps only the warning entry; the critical one is not considered.
        match = [re.compile('warn')]
        msg, state, _ = redfish.get_manager_logservices_sel_entries(
            SEL_MIXED_BODY, match=match
        )
        self.assertEqual(state, STATE_WARN)
        self.assertNotIn('Temp high', msg)
        self.assertIn('warn msg', msg)

    def test_cutoff_ages_out_old_entries(self):
        # A cutoff in 2033 ages out both 2021 non-OK entries; nothing drives state.
        msg, state, aged = redfish.get_manager_logservices_sel_entries(
            SEL_MIXED_BODY, cutoff_epoch=2_000_000_000
        )
        self.assertEqual(state, STATE_OK)
        self.assertEqual(aged, 2)
        self.assertEqual(msg, '')

    def test_undateable_entry_is_not_aged_out(self):
        # An unparseable Created keeps the entry rather than silently dropping it.
        body = {
            'Members': [{'Created': 'never', 'Message': 'm', 'Severity': 'Critical'}]
        }
        msg, state, aged = redfish.get_manager_logservices_sel_entries(
            body, cutoff_epoch=2_000_000_000
        )
        self.assertEqual(state, STATE_CRIT)
        self.assertEqual(aged, 0)
        self.assertIn('m', msg)


# ---------------------------------------------------------------------------
# get_perfdata
# ---------------------------------------------------------------------------
class TestGetPerfdata(unittest.TestCase):
    def test_percent_with_all_fields(self):
        data = {
            'Name': 'Temperature Sensor 1',
            'PhysicalContext': 'Chassis',
            'Reading': 75.0,
            'ReadingUnits': '%',
            'Thresholds_UpperCaution': 80,
            'Thresholds_UpperCritical': 90,
            'ReadingRangeMin': 1,
            'ReadingRangeMax': 100,
        }
        # label is built as PhysicalContext_Name with spaces -> underscores
        self.assertEqual(
            redfish.get_perfdata(data),
            "'Chassis_Temperature_Sensor_1'=75.0%;80;90;1;100 ",
        )

    def test_non_numeric_reading_returns_empty(self):
        self.assertEqual(redfish.get_perfdata({'Reading': '75'}), '')

    def test_missing_reading_returns_empty(self):
        self.assertEqual(redfish.get_perfdata({'Name': 'n'}), '')

    def test_none_reading_returns_empty(self):
        self.assertEqual(redfish.get_perfdata({'Reading': None}), '')

    def test_bool_reading_is_accepted_as_int(self):
        # bool is a subclass of int; document the actual behaviour.
        out = redfish.get_perfdata(
            {'Reading': True, 'Name': 'x', 'PhysicalContext': 'y'}
        )
        self.assertEqual(out, "'y_x'=True ")

    def test_non_percent_unit_dropped(self):
        # Only '%' is forwarded as UOM; 'Cel' etc. are dropped.
        out = redfish.get_perfdata(
            {'Reading': 22, 'Name': 'T', 'PhysicalContext': 'C', 'ReadingUnits': 'Cel'}
        )
        self.assertEqual(out, "'C_T'=22 ")

    def test_zero_range_bounds_dropped_via_or_none(self):
        # ReadingRangeMin/Max == 0 are falsy, so `or None` drops them.
        out = redfish.get_perfdata(
            {
                'Reading': 5,
                'Name': 'T',
                'PhysicalContext': 'C',
                'ReadingRangeMin': 0,
                'ReadingRangeMax': 0,
            }
        )
        self.assertEqual(out, "'C_T'=5 ")

    def test_custom_key(self):
        out = redfish.get_perfdata(
            {'ReadingCelsius': 22, 'Name': 'a', 'PhysicalContext': 'b'},
            key='ReadingCelsius',
        )
        self.assertEqual(out, "'b_a'=22 ")

    def test_label_built_from_empty_name_and_context(self):
        out = redfish.get_perfdata({'Reading': 5})
        self.assertEqual(out, "'_'=5 ")

    def test_warn_crit_forwarded(self):
        out = redfish.get_perfdata(
            {
                'Reading': 50,
                'Name': 'n',
                'PhysicalContext': 'p',
                'Thresholds_UpperCaution': 70,
                'Thresholds_UpperCritical': 90,
            }
        )
        self.assertEqual(out, "'p_n'=50;70;90 ")

    def test_matches_base_get_perfdata_contract(self):
        # The module is a thin wrapper around base.get_perfdata; assert they agree.
        data = {
            'Name': 'S 1',
            'PhysicalContext': 'Ctx',
            'Reading': 12.5,
            'ReadingUnits': '%',
            'Thresholds_UpperCaution': 80,
            'Thresholds_UpperCritical': 90,
            'ReadingRangeMin': 1,
            'ReadingRangeMax': 100,
        }
        expected = base.get_perfdata('Ctx_S_1', 12.5, '%', 80, 90, 1, 100)
        self.assertEqual(redfish.get_perfdata(data), expected)


# ---------------------------------------------------------------------------
# get_sensor_state
# ---------------------------------------------------------------------------
class TestGetSensorState(unittest.TestCase):
    BASE: typing.ClassVar = {
        'Status_State': 'Enabled',
        'Status_Health': '',
        'Status_HealthRollup': '',
    }

    def _state(self, **kw):
        data = dict(self.BASE)
        data.update(kw)
        return redfish.get_sensor_state(data)

    # 0. reading parsing
    def test_non_numeric_reading_is_ok(self):
        self.assertEqual(self._state(Reading='abc'), STATE_OK)

    def test_none_reading_is_ok(self):
        self.assertEqual(self._state(Reading=None), STATE_OK)

    def test_numeric_string_reading_is_parsed(self):
        # '95' parses; with upper critical 90 -> CRIT
        self.assertEqual(
            self._state(Reading='95', Thresholds_UpperCritical=90), STATE_CRIT
        )

    # 1. Status_State gate
    def test_disabled_state_short_circuits_ok(self):
        self.assertEqual(
            redfish.get_sensor_state(
                {'Reading': 5, 'Status_State': 'Disabled', 'Status_Health': 'Critical'}
            ),
            STATE_OK,
        )

    def test_absent_state_is_ok(self):
        self.assertEqual(
            redfish.get_sensor_state({'Reading': 5, 'Status_State': 'Absent'}), STATE_OK
        )

    def test_quiesced_state_is_evaluated(self):
        self.assertEqual(
            redfish.get_sensor_state(
                {'Reading': 5, 'Status_State': 'Quiesced', 'Status_Health': 'Critical'}
            ),
            STATE_CRIT,
        )

    # 2. health / healthrollup
    def test_health_critical(self):
        self.assertEqual(self._state(Reading=5, Status_Health='Critical'), STATE_CRIT)

    def test_health_warning(self):
        self.assertEqual(self._state(Reading=5, Status_Health='Warning'), STATE_WARN)

    def test_healthrollup_critical(self):
        self.assertEqual(
            self._state(Reading=5, Status_HealthRollup='Critical'), STATE_CRIT
        )

    def test_healthrollup_warning(self):
        self.assertEqual(
            self._state(Reading=5, Status_HealthRollup='Warning'), STATE_WARN
        )

    def test_health_case_insensitive(self):
        self.assertEqual(self._state(Reading=5, Status_Health='cRiTiCaL'), STATE_CRIT)

    def test_healthrollup_takes_precedence_over_health(self):
        # HealthRollup is checked first; Critical rollup wins over Warning health.
        self.assertEqual(
            self._state(
                Reading=5, Status_HealthRollup='Critical', Status_Health='Warning'
            ),
            STATE_CRIT,
        )

    # 3. thresholds
    def test_user_upper_critical_breach(self):
        self.assertEqual(
            self._state(
                Reading=95,
                Thresholds_UpperCriticalUser=85,
                Thresholds_UpperCritical=90,
                Thresholds_UpperCaution=80,
            ),
            STATE_CRIT,
        )

    def test_default_upper_critical_breach(self):
        self.assertEqual(
            self._state(Reading=92, Thresholds_UpperCritical=90), STATE_CRIT
        )

    def test_lower_critical_breach(self):
        self.assertEqual(
            self._state(Reading=5, Thresholds_LowerCritical=10), STATE_CRIT
        )

    def test_user_lower_critical_breach(self):
        self.assertEqual(
            self._state(Reading=5, Thresholds_LowerCriticalUser=10), STATE_CRIT
        )

    def test_user_upper_caution_breach(self):
        self.assertEqual(
            self._state(Reading=82, Thresholds_UpperCautionUser=81), STATE_WARN
        )

    def test_default_upper_caution_breach(self):
        self.assertEqual(
            self._state(Reading=82, Thresholds_UpperCaution=80), STATE_WARN
        )

    def test_lower_caution_breach(self):
        self.assertEqual(self._state(Reading=5, Thresholds_LowerCaution=10), STATE_WARN)

    def test_within_thresholds_is_ok(self):
        self.assertEqual(self._state(Reading=50, Thresholds_UpperCaution=80), STATE_OK)

    def test_critical_checked_before_caution(self):
        # Reading breaches both caution and critical; critical wins.
        self.assertEqual(
            self._state(
                Reading=95, Thresholds_UpperCaution=80, Thresholds_UpperCritical=90
            ),
            STATE_CRIT,
        )

    def test_threshold_string_values_parsed(self):
        self.assertEqual(
            self._state(Reading=92, Thresholds_UpperCritical='90'), STATE_CRIT
        )

    def test_unparseable_threshold_ignored(self):
        # A garbage threshold parses to None and is ignored -> no thresholds -> OK.
        self.assertEqual(
            self._state(Reading=92, Thresholds_UpperCritical='n/a'), STATE_OK
        )

    # 4. reading range fallback
    def test_range_outside_is_warn(self):
        self.assertEqual(
            self._state(Reading=150, ReadingRangeMin=0, ReadingRangeMax=100), STATE_WARN
        )

    def test_range_below_is_warn(self):
        self.assertEqual(
            self._state(Reading=-5, ReadingRangeMin=0, ReadingRangeMax=100), STATE_WARN
        )

    def test_range_inside_is_ok(self):
        self.assertEqual(
            self._state(Reading=50, ReadingRangeMin=0, ReadingRangeMax=100), STATE_OK
        )

    def test_only_range_min_no_fallback(self):
        # Both bounds are required for the range fallback.
        self.assertEqual(self._state(Reading=150, ReadingRangeMin=0), STATE_OK)

    def test_zero_width_range_is_ignored(self):
        # min == max is a zero-width range, used by some implementations (often 255)
        # as a sentinel for "not available"/"no limit". It must not flag the reading.
        self.assertEqual(
            self._state(Reading=1, ReadingRangeMin=255, ReadingRangeMax=255), STATE_OK
        )

    def test_thresholds_take_precedence_over_range(self):
        # Any threshold present skips the range branch entirely.
        self.assertEqual(
            self._state(
                Reading=50,
                Thresholds_UpperCaution=80,
                ReadingRangeMin=0,
                ReadingRangeMax=10,
            ),
            STATE_OK,
        )

    # 5. default
    def test_nothing_defined_is_ok(self):
        self.assertEqual(self._state(Reading=50), STATE_OK)

    def test_custom_key(self):
        self.assertEqual(
            redfish.get_sensor_state(
                {
                    'ReadingCelsius': 92,
                    'Status_State': 'Enabled',
                    'Thresholds_UpperCritical': 90,
                },
                key='ReadingCelsius',
            ),
            STATE_CRIT,
        )


# ---------------------------------------------------------------------------
# get_state
# ---------------------------------------------------------------------------
class TestGetState(unittest.TestCase):
    def test_healthrollup_critical(self):
        self.assertEqual(
            redfish.get_state(
                {'Status_State': 'Enabled', 'Status_HealthRollup': 'Critical'}
            ),
            STATE_CRIT,
        )

    def test_health_warning(self):
        self.assertEqual(
            redfish.get_state({'Status_State': 'Enabled', 'Status_Health': 'Warning'}),
            STATE_WARN,
        )

    def test_health_ok(self):
        self.assertEqual(
            redfish.get_state({'Status_State': 'Enabled', 'Status_Health': 'OK'}),
            STATE_OK,
        )

    def test_disabled_state_short_circuits_ok(self):
        self.assertEqual(
            redfish.get_state(
                {'Status_State': 'Disabled', 'Status_Health': 'Critical'}
            ),
            STATE_OK,
        )

    def test_absent_state_is_ok(self):
        self.assertEqual(
            redfish.get_state(
                {'Status_State': 'Absent', 'Status_HealthRollup': 'Critical'}
            ),
            STATE_OK,
        )

    def test_quiesced_state_is_evaluated(self):
        self.assertEqual(
            redfish.get_state({'Status_State': 'Quiesced', 'Status_Health': 'Warning'}),
            STATE_WARN,
        )

    def test_healthrollup_precedence(self):
        self.assertEqual(
            redfish.get_state(
                {
                    'Status_State': 'Enabled',
                    'Status_HealthRollup': 'Critical',
                    'Status_Health': 'Warning',
                }
            ),
            STATE_CRIT,
        )

    def test_case_insensitive(self):
        self.assertEqual(
            redfish.get_state({'Status_State': 'Enabled', 'Status_Health': 'warning'}),
            STATE_WARN,
        )

    def test_missing_state_key_is_ok(self):
        # No Status_State at all -> not in ('Enabled','Quiesced') -> OK.
        self.assertEqual(redfish.get_state({'Status_Health': 'Critical'}), STATE_OK)

    def test_empty_dict_is_ok(self):
        self.assertEqual(redfish.get_state({}), STATE_OK)


# ---------------------------------------------------------------------------
# get_systems
# ---------------------------------------------------------------------------
class TestGetSystems(unittest.TestCase):
    def test_full_payload(self):
        body = {
            'BiosVersion': '1.0.0',
            'HostName': 'System1',
            'Id': '12345',
            'IndicatorLED': 'Off',
            'Manufacturer': 'Dell',
            'Model': 'R750',
            'PowerState': 'On',
            'SerialNumber': 'SN1',
            'SKU': 'SKU1',
            'ProcessorSummary': {
                'Count': 2,
                'LogicalProcessorCount': 4,
                'Model': 'Intel Xeon',
            },
            'Storage': {'@odata.id': '/redfish/v1/Systems/1/Storage'},
            'Status': {'State': 'Enabled', 'Health': 'OK', 'HealthRollup': 'OK'},
        }
        out = redfish.get_systems(body)
        self.assertEqual(out['BiosVersion'], '1.0.0')
        self.assertEqual(out['HostName'], 'System1')
        self.assertEqual(out['ProcessorSummary_Count'], 2)
        self.assertEqual(out['ProcessorSummary_LogicalProcessorCount'], 4)
        self.assertEqual(out['ProcessorSummary_Model'], 'Intel Xeon')
        self.assertEqual(out['Storage_@odata.id'], '/redfish/v1/Systems/1/Storage')
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')
        self.assertEqual(out['Status_HealthRollup'], 'OK')

    def test_empty(self):
        out = redfish.get_systems({})
        for key in redfish.SYSTEMS_KEYS:
            self.assertEqual(out[key], '')
        for key in redfish.SYSTEMS_NESTED_KEYS:
            self.assertEqual(out[key], '')

    def test_non_scalar_nested_filtered(self):
        out = redfish.get_systems({'ProcessorSummary': {'Count': {'x': 1}}})
        self.assertEqual(out['ProcessorSummary_Count'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems({})
        expected = set(redfish.SYSTEMS_KEYS) | set(redfish.SYSTEMS_NESTED_KEYS)
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_systems_memory (CapacityMiB humanizing + vendor quirks)
# ---------------------------------------------------------------------------
class TestGetSystemsMemory(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_systems_memory(
            {
                'CapacityMiB': 32768,
                'Id': 'DIMM1',
                'MemoryDeviceType': 'DDR4',
                'Name': 'DIMM Slot 1',
                'Status': {'State': 'Enabled', 'Health': 'OK', 'HealthRollup': 'OK'},
            }
        )
        self.assertEqual(out['CapacityMiB'], human.bytes2human(32768 * 1024 * 1024))
        self.assertEqual(out['MemoryDeviceType'], 'DDR4')
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_capacity_missing_is_empty(self):
        self.assertEqual(redfish.get_systems_memory({})['CapacityMiB'], '')

    def test_capacity_size_mb_fallback(self):
        out = redfish.get_systems_memory({'SizeMB': 8192})
        self.assertEqual(out['CapacityMiB'], human.bytes2human(8192 * 1024 * 1024))

    def test_dell_idrac8_size_division(self):
        # vendor quirk: Dell reports decimal MB when the value is not a clean
        # MiB multiple; 16000 -> round(16000 * 1024**2 / 1000**2) = 16777 MiB
        out = redfish.get_systems_memory({'CapacityMiB': 16000, 'Oem': {'Dell': {}}})
        self.assertEqual(out['CapacityMiB'], human.bytes2human(16777 * 1024 * 1024))

    def test_dell_clean_multiple_unchanged(self):
        out = redfish.get_systems_memory({'CapacityMiB': 16384, 'Oem': {'Dell': {}}})
        self.assertEqual(out['CapacityMiB'], human.bytes2human(16384 * 1024 * 1024))

    def test_non_dell_size_unchanged(self):
        out = redfish.get_systems_memory({'CapacityMiB': 16000, 'Oem': {'Hpe': {}}})
        self.assertEqual(out['CapacityMiB'], human.bytes2human(16000 * 1024 * 1024))

    def test_hpe_dimmstatus_healthy(self):
        # vendor quirk: HPE reports operational state in Oem.Hpe.DIMMStatus
        out = redfish.get_systems_memory({'Oem': {'Hpe': {'DIMMStatus': 'GoodInUse'}}})
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_hpe_dimmstatus_bad_is_flagged(self):
        out = redfish.get_systems_memory(
            {'Oem': {'Hpe': {'DIMMStatus': 'DegradedInUse'}}}
        )
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'Critical')
        self.assertEqual(redfish.get_state(out), STATE_CRIT)

    def test_hpe_dimmstatus_absent(self):
        out = redfish.get_systems_memory({'Oem': {'Hpe': {'DIMMStatus': 'NotPresent'}}})
        self.assertEqual(out['Status_State'], 'Absent')

    def test_fujitsu_signal_legacy_status_ok(self):
        # vendor quirk: Fujitsu uses SignalStatus (state) + LegacyStatus (health)
        out = redfish.get_systems_memory(
            {'Oem': {'Fujitsu': {'SignalStatus': 'Enabled', 'LegacyStatus': 'Ok'}}}
        )
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_fujitsu_legacy_status_error_is_flagged(self):
        out = redfish.get_systems_memory(
            {'Oem': {'Fujitsu': {'SignalStatus': 'Enabled', 'LegacyStatus': 'Error'}}}
        )
        self.assertEqual(out['Status_Health'], 'Critical')
        self.assertEqual(redfish.get_state(out), STATE_CRIT)

    def test_generic_top_level_dimmstatus(self):
        out = redfish.get_systems_memory({'DIMMStatus': 'GoodInUse'})
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems_memory({})
        expected = set(redfish.MEMORY_KEYS) | set(redfish.MEMORY_NESTED_KEYS)
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_systems_storage
# ---------------------------------------------------------------------------
class TestGetSystemsStorage(unittest.TestCase):
    def test_full_payload(self):
        body = {
            'Description': 'RAID Storage',
            'Drives@odata.count': 5,
            'Id': '6789',
            'Name': 'StorageSystem1',
            'Status': {'State': 'Enabled', 'Health': 'OK', 'HealthRollup': 'OK'},
        }
        self.assertEqual(
            redfish.get_systems_storage(body),
            {
                'Description': 'RAID Storage',
                'Drives@odata.count': 5,
                'Id': '6789',
                'Name': 'StorageSystem1',
                'Volumes_@odata.id': '',
                'Status_State': 'Enabled',
                'Status_Health': 'OK',
                'Status_HealthRollup': 'OK',
            },
        )

    def test_empty(self):
        out = redfish.get_systems_storage({})
        for key in redfish.SYSTEMS_STORAGE_KEYS:
            self.assertEqual(out[key], '')
        for key in redfish.SYSTEMS_STORAGE_NESTED_KEYS:
            self.assertEqual(out[key], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems_storage({})
        expected = set(redfish.SYSTEMS_STORAGE_KEYS) | set(
            redfish.SYSTEMS_STORAGE_NESTED_KEYS
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_systems_storage_drives (CapacityBytes humanizing)
# ---------------------------------------------------------------------------
class TestGetSystemsStorageDrives(unittest.TestCase):
    def test_full_payload(self):
        out = redfish.get_systems_storage_drives(load(DRIVE_BODY))
        self.assertEqual(out['BlockSizeBytes'], 512)
        self.assertEqual(out['CapableSpeedGbs'], 12)
        self.assertEqual(out['Description'], 'Disk Drive Bay 0')
        self.assertEqual(out['MediaType'], 'SSD')
        self.assertEqual(out['Model'], '970 EVO')
        self.assertEqual(out['Protocol'], 'NVMe')
        self.assertEqual(out['SerialNumber'], 'S1234NEAB00001')
        self.assertEqual(out['Status_State'], 'Enabled')
        self.assertEqual(out['Status_Health'], 'OK')
        self.assertEqual(out['Status_HealthRollup'], 'OK')
        # CapacityBytes is humanized via lib.human.bytes2human.
        self.assertEqual(out['CapacityBytes'], CAP_500GB)

    def test_capacity_matches_human_helper(self):
        out = redfish.get_systems_storage_drives({'CapacityBytes': 500000000000})
        self.assertEqual(out['CapacityBytes'], human.bytes2human(500000000000))

    def test_capacity_missing_is_empty(self):
        out = redfish.get_systems_storage_drives({})
        self.assertEqual(out['CapacityBytes'], '')

    def test_capacity_zero_is_empty(self):
        # `if capacity` is falsy for 0 -> '' rather than bytes2human(0).
        out = redfish.get_systems_storage_drives({'CapacityBytes': 0})
        self.assertEqual(out['CapacityBytes'], '')

    def test_failure_predicted_false_preserved(self):
        out = redfish.get_systems_storage_drives({'FailurePredicted': False})
        self.assertEqual(out['FailurePredicted'], False)

    def test_temperature_from_current_temperature_celsius(self):
        # vendor quirk: HPE SmartStorage exposes CurrentTemperatureCelsius
        out = redfish.get_systems_storage_drives({'CurrentTemperatureCelsius': 37})
        self.assertEqual(out['Temperature'], 37)

    def test_temperature_from_oem_temperature_celsius(self):
        out = redfish.get_systems_storage_drives(
            {'Oem': {'Hpe': {'TemperatureCelsius': 41}}}
        )
        self.assertEqual(out['Temperature'], 41)

    def test_temperature_from_oem_temperature_c(self):
        out = redfish.get_systems_storage_drives(
            {'Oem': {'Dell': {'TemperatureC': 29}}}
        )
        self.assertEqual(out['Temperature'], 29)

    def test_temperature_missing_is_empty(self):
        out = redfish.get_systems_storage_drives({})
        self.assertEqual(out['Temperature'], '')

    def test_output_key_set_is_exact(self):
        out = redfish.get_systems_storage_drives({})
        # CapacityBytes and Temperature are added on top of the flat + nested key
        # sets.
        expected = (
            set(redfish.SYSTEMS_STORAGE_DRIVES_KEYS)
            | set(redfish.SYSTEMS_STORAGE_DRIVES_NESTED_KEYS)
            | {'CapacityBytes', 'Temperature'}
        )
        self.assertEqual(set(out), expected)


# ---------------------------------------------------------------------------
# get_vendor
# ---------------------------------------------------------------------------
class TestGetVendor(unittest.TestCase):
    def test_explicit_vendor_lowercased(self):
        self.assertEqual(redfish.get_vendor({'Vendor': 'DELL'}), 'dell')

    def test_oem_first_key_used(self):
        self.assertEqual(redfish.get_vendor({'Oem': {'SomeVendor': 'x'}}), 'somevendor')

    def test_empty_dict_is_generic(self):
        self.assertEqual(redfish.get_vendor({}), 'generic')

    def test_empty_oem_is_generic(self):
        self.assertEqual(redfish.get_vendor({'Oem': {}}), 'generic')

    def test_vendor_none_falls_back_to_oem(self):
        self.assertEqual(redfish.get_vendor({'Vendor': None, 'Oem': {'Hpe': 1}}), 'hpe')

    def test_vendor_empty_string_falls_back_to_oem(self):
        self.assertEqual(
            redfish.get_vendor({'Vendor': '', 'Oem': {'Lenovo': 1}}), 'lenovo'
        )

    def test_oem_none_is_generic(self):
        # `redfish.get('Oem') or {}` guards an explicit None Oem.
        self.assertEqual(redfish.get_vendor({'Oem': None}), 'generic')

    def test_vendor_wins_over_oem(self):
        self.assertEqual(
            redfish.get_vendor({'Vendor': 'Dell', 'Oem': {'Hpe': 1}}), 'dell'
        )


# ---------------------------------------------------------------------------
# build_url (@odata.id SSRF pinning)
# ---------------------------------------------------------------------------
class TestBuildUrl(unittest.TestCase):
    def test_relative_link_is_pinned_to_base_host(self):
        self.assertEqual(
            redfish.build_url('https://bmc', '/redfish/v1/Systems/1'),
            (True, 'https://bmc/redfish/v1/Systems/1'),
        )

    def test_base_host_wins_over_link_authority(self):
        # the @odata.id can only supply a path, never a new host
        ok, url_out = redfish.build_url('https://bmc', '/redfish/v1/x')
        self.assertTrue(ok)
        self.assertTrue(url_out.startswith('https://bmc/'))

    def test_userinfo_injection_is_refused(self):
        ok, err = redfish.build_url('https://bmc', '@evil.example.com/x')
        self.assertFalse(ok)
        self.assertIn('Refusing', err)

    def test_protocol_relative_link_is_refused(self):
        ok, err = redfish.build_url('https://bmc', '//evil.example.com/x')
        self.assertFalse(ok)
        self.assertIn('Refusing', err)

    def test_non_string_link_is_refused(self):
        ok, err = redfish.build_url('https://bmc', None)
        self.assertFalse(ok)
        self.assertIn('Refusing', err)


# ---------------------------------------------------------------------------
# fetch_collection ($expand with plain fallback; lib.url is mocked)
# ---------------------------------------------------------------------------
class TestFetchCollection(unittest.TestCase):
    @mock.patch.object(redfish, 'url')
    def test_expand_success_is_a_single_request(self, url_mock):
        coll = {'Members': [{'@odata.id': '/x/1', 'Id': '1'}]}
        url_mock.fetch_json.return_value = (True, coll)
        ok, out = redfish.fetch_collection('https://bmc/redfish/v1/Chassis/1/Sensors')
        self.assertTrue(ok)
        self.assertEqual(out, coll)
        self.assertEqual(url_mock.fetch_json.call_count, 1)
        # the single request carries the $expand query
        self.assertIn('$expand=.($levels=1)', url_mock.fetch_json.call_args[0][0])

    @mock.patch.object(redfish, 'url')
    def test_custom_expand_suffix_is_used(self, url_mock):
        url_mock.fetch_json.return_value = (True, {'Members': []})
        redfish.fetch_collection('https://bmc/x', expand='?$expand=*($levels=3)')
        self.assertIn('$expand=*($levels=3)', url_mock.fetch_json.call_args[0][0])

    @mock.patch.object(redfish, 'url')
    def test_expand_rejected_falls_back_to_plain(self, url_mock):
        plain = {'Members': [{'@odata.id': '/x/1'}]}
        url_mock.fetch_json.side_effect = [(False, 'HTTP 400'), (True, plain)]
        ok, out = redfish.fetch_collection('https://bmc/redfish/v1/Chassis/1/Sensors')
        self.assertTrue(ok)
        self.assertEqual(out, plain)
        self.assertEqual(url_mock.fetch_json.call_count, 2)
        # the fallback request drops the $expand query
        self.assertNotIn('$expand', url_mock.fetch_json.call_args_list[1][0][0])

    @mock.patch.object(redfish, 'url')
    def test_expand_non_dict_falls_back_to_plain(self, url_mock):
        url_mock.fetch_json.side_effect = [(True, 'not-a-dict'), (True, {'Members': []})]
        ok, out = redfish.fetch_collection('https://bmc/x')
        self.assertTrue(ok)
        self.assertEqual(out, {'Members': []})
        self.assertEqual(url_mock.fetch_json.call_count, 2)

    @mock.patch.object(redfish, 'url')
    def test_both_requests_fail_propagates_error(self, url_mock):
        url_mock.fetch_json.side_effect = [(False, 'boom'), (False, 'boom2')]
        ok, out = redfish.fetch_collection('https://bmc/x')
        self.assertFalse(ok)
        self.assertEqual(out, 'boom2')

    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cache_hit_skips_the_request(self, url_mock, cache_mock):
        cache_mock.get.return_value = json.dumps({'Members': [{'Id': '1'}]})
        ok, out = redfish.fetch_collection('https://bmc/x', cache_expire=300)
        self.assertTrue(ok)
        self.assertEqual(out, {'Members': [{'Id': '1'}]})
        url_mock.fetch_json.assert_not_called()

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cache_miss_fetches_and_fills_by_plain_url(self, url_mock, cache_mock, time_mock):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        coll = {'Members': [{'@odata.id': '/x/1', 'Id': '1'}]}
        url_mock.fetch_json.return_value = (True, coll)
        ok, out = redfish.fetch_collection('https://bmc/x', cache_expire=300)
        self.assertTrue(ok)
        self.assertEqual(out, coll)
        # cached under the plain URL (not the $expand variant)
        cache_mock.set.assert_called_once_with(
            'redfish-https://bmc/x',
            json.dumps(coll),
            1000 + 300,
            filename=redfish.CACHE_FILENAME,
        )


# ---------------------------------------------------------------------------
# get_expand_suffix (derive the deepest advertised $expand; lib.url is mocked)
# ---------------------------------------------------------------------------
def _root(**expand_query):
    """A service-root document advertising the given ExpandQuery support."""
    return (True, {'ProtocolFeaturesSupported': {'ExpandQuery': expand_query}})


class TestGetExpandSuffix(unittest.TestCase):
    @mock.patch.object(redfish, 'url')
    def test_expandall_uses_star_and_caps_levels(self, url_mock):
        # MaxLevels 9 is capped at MAX_EXPAND_LEVELS (3)
        url_mock.fetch_json.return_value = _root(
            ExpandAll=True, Levels=True, MaxLevels=9
        )
        self.assertEqual(
            redfish.get_expand_suffix('https://bmc'), '?$expand=*($levels=3)'
        )

    @mock.patch.object(redfish, 'url')
    def test_maxlevels_below_cap_is_honoured(self, url_mock):
        url_mock.fetch_json.return_value = _root(
            ExpandAll=True, Levels=True, MaxLevels=1
        )
        self.assertEqual(
            redfish.get_expand_suffix('https://bmc'), '?$expand=*($levels=1)'
        )

    @mock.patch.object(redfish, 'url')
    def test_nolinks_only_uses_dot_operator(self, url_mock):
        url_mock.fetch_json.return_value = _root(
            ExpandAll=False, NoLinks=True, Levels=True, MaxLevels=2
        )
        self.assertEqual(
            redfish.get_expand_suffix('https://bmc'), '?$expand=.($levels=2)'
        )

    @mock.patch.object(redfish, 'url')
    def test_no_levels_support_omits_levels_clause(self, url_mock):
        url_mock.fetch_json.return_value = _root(ExpandAll=True, Levels=False)
        self.assertEqual(redfish.get_expand_suffix('https://bmc'), '?$expand=*')

    @mock.patch.object(redfish, 'url')
    def test_no_expand_support_returns_default(self, url_mock):
        url_mock.fetch_json.return_value = (True, {'ProtocolFeaturesSupported': {}})
        self.assertEqual(redfish.get_expand_suffix('https://bmc'), redfish.DEFAULT_EXPAND)

    @mock.patch.object(redfish, 'url')
    def test_unreadable_root_returns_default(self, url_mock):
        url_mock.fetch_json.return_value = (False, 'HTTP 500')
        self.assertEqual(redfish.get_expand_suffix('https://bmc'), redfish.DEFAULT_EXPAND)


# ---------------------------------------------------------------------------
# fetch_members (populate bare refs, skip expanded; lib.url is mocked)
# ---------------------------------------------------------------------------
class TestFetchMembers(unittest.TestCase):
    @mock.patch.object(redfish, 'url')
    def test_all_expanded_makes_no_requests(self, url_mock):
        members = [{'@odata.id': '/x/1', 'Id': '1'}, {'@odata.id': '/x/2', 'Reading': 5}]
        ok, out = redfish.fetch_members(members, 'https://bmc')
        self.assertTrue(ok)
        self.assertEqual(out, members)
        url_mock.fetch_json.assert_not_called()

    @mock.patch.object(redfish, 'url')
    def test_bare_refs_are_fetched_and_host_is_pinned(self, url_mock):
        url_mock.fetch_json.side_effect = [
            (True, {'Id': '1', 'Reading': 1}),
            (True, {'Id': '2', 'Reading': 2}),
        ]
        members = [{'@odata.id': '/redfish/v1/x/1'}, {'@odata.id': '/redfish/v1/x/2'}]
        ok, out = redfish.fetch_members(members, 'https://bmc')
        self.assertTrue(ok)
        self.assertEqual(out, [{'Id': '1', 'Reading': 1}, {'Id': '2', 'Reading': 2}])
        self.assertEqual(url_mock.fetch_json.call_count, 2)
        self.assertEqual(
            url_mock.fetch_json.call_args_list[0][0][0], 'https://bmc/redfish/v1/x/1'
        )

    @mock.patch.object(redfish, 'url')
    def test_mixed_expanded_and_bare_only_fetches_the_bare_one(self, url_mock):
        url_mock.fetch_json.return_value = (True, {'Id': '2', 'Reading': 2})
        members = [{'@odata.id': '/x/1', 'Id': '1'}, {'@odata.id': '/redfish/v1/x/2'}]
        ok, out = redfish.fetch_members(members, 'https://bmc')
        self.assertTrue(ok)
        self.assertEqual(out[0], {'@odata.id': '/x/1', 'Id': '1'})
        self.assertEqual(out[1], {'Id': '2', 'Reading': 2})
        self.assertEqual(url_mock.fetch_json.call_count, 1)

    @mock.patch.object(redfish, 'url')
    def test_malformed_odata_id_is_refused_without_request(self, url_mock):
        ok, out = redfish.fetch_members([{'@odata.id': '@evil/x'}], 'https://bmc')
        self.assertFalse(ok)
        self.assertIn('Refusing', out)
        url_mock.fetch_json.assert_not_called()

    @mock.patch.object(redfish, 'url')
    def test_member_fetch_failure_propagates(self, url_mock):
        url_mock.fetch_json.return_value = (False, 'Bad Gateway')
        ok, out = redfish.fetch_members([{'@odata.id': '/redfish/v1/x/1'}], 'https://bmc')
        self.assertFalse(ok)
        self.assertEqual(out, 'Bad Gateway')

    @mock.patch.object(redfish, 'url')
    def test_non_dict_member_is_skipped(self, url_mock):
        members = ['not-a-dict', {'@odata.id': '/x/1', 'Id': '1'}]
        ok, out = redfish.fetch_members(members, 'https://bmc')
        self.assertTrue(ok)
        self.assertEqual(out, [{'@odata.id': '/x/1', 'Id': '1'}])
        url_mock.fetch_json.assert_not_called()

    def test_empty_members_returns_empty_list(self):
        self.assertEqual(redfish.fetch_members([], 'https://bmc'), (True, []))

    @mock.patch.object(redfish, 'time')
    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_bare_member_is_cached_by_url(self, url_mock, cache_mock, time_mock):
        cache_mock.get.return_value = False
        time_mock.now.return_value = 1000
        url_mock.fetch_json.return_value = (True, {'Id': '1'})
        ok, out = redfish.fetch_members(
            [{'@odata.id': '/redfish/v1/x/1'}], 'https://bmc', cache_expire=300
        )
        self.assertTrue(ok)
        self.assertEqual(out, [{'Id': '1'}])
        cache_mock.set.assert_called_once_with(
            'redfish-https://bmc/redfish/v1/x/1',
            json.dumps({'Id': '1'}),
            1000 + 300,
            filename=redfish.CACHE_FILENAME,
        )

    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cached_member_skips_the_request(self, url_mock, cache_mock):
        cache_mock.get.return_value = json.dumps({'Id': '1'})
        ok, out = redfish.fetch_members(
            [{'@odata.id': '/redfish/v1/x/1'}], 'https://bmc', cache_expire=300
        )
        self.assertTrue(ok)
        self.assertEqual(out, [{'Id': '1'}])
        url_mock.fetch_json.assert_not_called()


# ---------------------------------------------------------------------------
# fetch_resource (cached plain GET, no $expand; lib.url is mocked)
# ---------------------------------------------------------------------------
class TestFetchResource(unittest.TestCase):
    @mock.patch.object(redfish, 'url')
    def test_plain_get_without_expand(self, url_mock):
        url_mock.fetch_json.return_value = (True, {'Vendor': 'Contoso'})
        ok, out = redfish.fetch_resource('https://bmc/redfish/v1/')
        self.assertTrue(ok)
        self.assertEqual(out, {'Vendor': 'Contoso'})
        self.assertEqual(url_mock.fetch_json.call_count, 1)
        self.assertNotIn('$expand', url_mock.fetch_json.call_args[0][0])

    @mock.patch.object(redfish, 'cache')
    @mock.patch.object(redfish, 'url')
    def test_cache_hit_skips_the_request(self, url_mock, cache_mock):
        cache_mock.get.return_value = json.dumps({'Vendor': 'Contoso'})
        ok, out = redfish.fetch_resource('https://bmc/redfish/v1/', cache_expire=300)
        self.assertTrue(ok)
        self.assertEqual(out, {'Vendor': 'Contoso'})
        url_mock.fetch_json.assert_not_called()

    @mock.patch.object(redfish, 'url')
    def test_failure_propagates(self, url_mock):
        url_mock.fetch_json.return_value = (False, 'HTTP 500')
        ok, out = redfish.fetch_resource('https://bmc/redfish/v1/')
        self.assertFalse(ok)
        self.assertEqual(out, 'HTTP 500')


# ---------------------------------------------------------------------------
# is_member_expanded (populated vs bare-reference detection)
# ---------------------------------------------------------------------------
class TestIsMemberExpanded(unittest.TestCase):
    def test_bare_reference_is_not_expanded(self):
        self.assertFalse(redfish.is_member_expanded({'@odata.id': '/x/1'}))

    def test_only_odata_annotations_is_not_expanded(self):
        self.assertFalse(
            redfish.is_member_expanded(
                {'@odata.id': '/x/1', '@odata.type': '#Sensor.v1_0_0.Sensor'}
            )
        )

    def test_populated_member_is_expanded(self):
        self.assertTrue(
            redfish.is_member_expanded({'@odata.id': '/x/1', 'Reading': 22.5})
        )

    def test_empty_dict_is_not_expanded(self):
        self.assertFalse(redfish.is_member_expanded({}))

    def test_non_dict_is_not_expanded(self):
        self.assertFalse(redfish.is_member_expanded('nope'))
        self.assertFalse(redfish.is_member_expanded(None))


if __name__ == '__main__':
    unittest.main()
