            'LowerThresholdNonCritical': 11,
            'Name': 'VCORE',
            'PhysicalContext': 'VoltageRegulator',
            'ReadingVolts': 12,
            'UpperThresholdCritical': 14,
            'UpperThresholdFatal': 15,
            'UpperThresholdNonCritical': 13,
