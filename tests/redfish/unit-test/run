    "@odata.id": "/redfish/v1/Chassis/1",
    "AssetTag": "LF-ASSET-001",
    "ChassisType": "RackMount",
    "Id": "1",
    "IndicatorLED": "Off",
    "Manufacturer": "Dell Inc.",
    "Model": "PowerEdge R750",
    "PartNumber": "0ABCDE",
    "PowerState": "On",
    "SerialNumber": "SN1234567",
    "SKU": "SKU-9000",
    "Sensors": {"@odata.id": "/redfish/v1/Chassis/1/Sensors"},
    "Status": {"State": "Enabled", "Health": "OK", "HealthRollup": "OK"}
}
"""

SENSOR_BODY = """
{
    "Id": "TempCPU1",
    "Name": "CPU 1 Temp",
    "PhysicalContext": "CPU",
    "Reading": 55.0,
    "ReadingRangeMax": 120,
    "ReadingRangeMin": 0,
