"""Unit tests for lib.disk file helpers, driven by throwaway temp files.

Host-inspecting helpers (get_real_disks, bd2dmd, udevadm) need real block
devices and belong to the container batch; get_block_devices is checked
only for its return shape here.
"""

import os
import sys
import tempfile
import unittest

sys.path.insert(0, '..')

import lib.disk as disk


class TestFileHelpers(unittest.TestCase):
    def setUp(self):
        self.dir = tempfile.mkdtemp(prefix='lftest-disk-')
        self.file = os.path.join(self.dir, 'x.txt')

    def test_write_read_roundtrip(self):
        self.assertEqual(disk.write_file(self.file, 'hello'), (True, None))
        self.assertEqual(disk.read_file(self.file), (True, 'hello'))

    def test_write_append(self):
        disk.write_file(self.file, 'a')
        disk.write_file(self.file, 'b', append=True)
        self.assertEqual(disk.read_file(self.file), (True, 'ab'))

    def test_dir_and_file_exists(self):
        disk.write_file(self.file, 'x')
        self.assertTrue(disk.dir_exists(self.dir))
        self.assertTrue(disk.file_exists(self.file))
        self.assertFalse(disk.file_exists(os.path.join(self.dir, 'nope')))

    def test_file_exists_allow_empty_parameter(self):
        empty = os.path.join(self.dir, 'empty')
        disk.write_file(empty, '')
        self.assertFalse(disk.file_exists(empty))
        self.assertTrue(disk.file_exists(empty, allow_empty=True))

    def test_grep_file_returns_first_group(self):
        disk.write_file(self.file, 'hello')
        self.assertEqual(disk.grep_file(self.file, 'he(l+)o'), (True, 'll'))

    def test_read_env(self):
        envfile = os.path.join(self.dir, 'env')
        disk.write_file(envfile, 'FOO=bar\nBAZ=qux\n')
        self.assertEqual(disk.read_env(envfile), (True, {'FOO': 'bar', 'BAZ': 'qux'}))

    def test_rm_file(self):
        disk.write_file(self.file, 'x')
        disk.rm_file(self.file)
        self.assertFalse(disk.file_exists(self.file))

    def test_walk_directory_finds_file(self):
        disk.write_file(self.file, 'x')
        found = disk.walk_directory(self.dir)
        self.assertTrue(any('x.txt' in f for f in found))

    @unittest.skipUnless(hasattr(os, 'geteuid'), 'POSIX-only ownership')
    def test_get_owner(self):
        disk.write_file(self.file, 'x')
        self.assertEqual(disk.get_owner(self.file), os.geteuid())


class TestMkdir(unittest.TestCase):
    def setUp(self):
        self.dir = tempfile.mkdtemp(prefix='lftest-disk-mkdir-')

    def test_creates_nested(self):
        target = os.path.join(self.dir, 'a', 'b', 'c')
        self.assertEqual(disk.mkdir(target), (True, None))
        self.assertTrue(os.path.isdir(target))

    def test_idempotent_with_exist_ok(self):
        target = os.path.join(self.dir, 'sub')
        disk.mkdir(target)
        self.assertEqual(disk.mkdir(target), (True, None))

    def test_exist_ok_false_on_existing_is_error(self):
        ok, err = disk.mkdir(self.dir, exist_ok=False)
        self.assertFalse(ok)
        self.assertIsInstance(err, str)


class TestTreeOps(unittest.TestCase):
    def setUp(self):
        self.base = tempfile.mkdtemp(prefix='lftest-disk-tree-')

    def test_make_temp_dir(self):
        ok, path = disk.make_temp_dir(prefix='lftest-mtd-')
        self.assertTrue(ok)
        self.assertTrue(os.path.isdir(path))
        disk.rm_dir(path)

    def test_copy_file_copy_dir_rm_dir_roundtrip(self):
        src = os.path.join(self.base, 'src')
        os.makedirs(src)
        disk.write_file(os.path.join(src, 'a.txt'), 'x')

        dst_file = os.path.join(self.base, 'a-copy.txt')
        self.assertEqual(
            disk.copy_file(os.path.join(src, 'a.txt'), dst_file), (True, None)
        )
        self.assertTrue(os.path.isfile(dst_file))

        dst_dir = os.path.join(self.base, 'dst')
        self.assertEqual(disk.copy_dir(src, dst_dir), (True, None))
        self.assertTrue(os.path.isfile(os.path.join(dst_dir, 'a.txt')))

        self.assertEqual(disk.rm_dir(dst_dir), (True, None))
        self.assertFalse(os.path.isdir(dst_dir))

    def test_copy_dir_existing_dst_is_error(self):
        ok, err = disk.copy_dir(self.base, self.base)
        self.assertFalse(ok)
        self.assertIsInstance(err, str)

    def test_rm_dir_missing_is_error(self):
        ok, err = disk.rm_dir(os.path.join(self.base, 'does-not-exist'))
        self.assertFalse(ok)
        self.assertIsInstance(err, str)


class TestHostHelpers(unittest.TestCase):
    def test_get_tmpdir_absolute_without_trailing_slash(self):
        tmp = disk.get_tmpdir()
        self.assertTrue(os.path.isabs(tmp))
        self.assertFalse(tmp.endswith('/'))

    def test_get_cwd_returns_path(self):
        self.assertTrue(os.path.isdir(disk.get_cwd()))

    def test_get_block_devices_returns_list(self):
        self.assertIsInstance(disk.get_block_devices(), list)


class TestShortenPath(unittest.TestCase):
    def test_abbreviates_parents_keeps_basename(self):
        self.assertEqual(
            disk.shorten_path('/etc/pki/tls/certs/002c0b4f.0'),
            '/e/p/t/c/002c0b4f.0',
        )
        self.assertEqual(
            disk.shorten_path('/usr/share/icingaweb2/public/index.php'),
            '/u/s/i/p/index.php',
        )

    def test_two_segment_path(self):
        self.assertEqual(disk.shorten_path('/srv/index.php'), '/s/index.php')

    def test_top_level_file_stays(self):
        self.assertEqual(disk.shorten_path('/index.php'), '/index.php')

    def test_relative_path(self):
        self.assertEqual(disk.shorten_path('relative/path/file'), 'r/p/file')

    def test_no_slash_passthrough(self):
        self.assertEqual(disk.shorten_path('index.php'), 'index.php')
        self.assertEqual(disk.shorten_path('-'), '-')
        self.assertEqual(disk.shorten_path(''), '')

    def test_root_stays(self):
        self.assertEqual(disk.shorten_path('/'), '/')


if __name__ == '__main__':
    unittest.main()
