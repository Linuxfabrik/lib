"""Unit tests for lib.disk file helpers, driven by throwaway temp files.

Host-inspecting helpers (get_real_disks, bd2dmd, udevadm) need real block
devices and belong to the container batch; get_block_devices is checked
only for its return shape here.
"""

import os
import shutil
import sys
import tempfile
import unittest

sys.path.insert(0, '..')

import lib.disk as disk


class TestFileHelpers(unittest.TestCase):
    def setUp(self):
        self.dir = tempfile.mkdtemp(prefix='lftest-disk-')
        self.file = os.path.join(self.dir, 'x.txt')

    def test_write_read_roundtrip(self):
        self.assertEqual(disk.write_file(self.file, 'hello'), (True, None))
        self.assertEqual(disk.read_file(self.file), (True, 'hello'))

    def test_read_file_binary(self):
        disk.write_file(self.file, 'héllo')
        self.assertEqual(disk.read_file(self.file, binary=True), (True, 'héllo'.encode()))

    def test_write_append(self):
        disk.write_file(self.file, 'a')
        disk.write_file(self.file, 'b', append=True)
        self.assertEqual(disk.read_file(self.file), (True, 'ab'))

    def test_dir_and_file_exists(self):
        disk.write_file(self.file, 'x')
        self.assertTrue(disk.dir_exists(self.dir))
        self.assertTrue(disk.file_exists(self.file))
        self.assertFalse(disk.file_exists(os.path.join(self.dir, 'nope')))

    def test_file_exists_allow_empty_parameter(self):
        empty = os.path.join(self.dir, 'empty')
        disk.write_file(empty, '')
        self.assertFalse(disk.file_exists(empty))
        self.assertTrue(disk.file_exists(empty, allow_empty=True))

    def test_get_fingerprint_hashes_the_head_only(self):
        disk.write_file(self.file, 'head' + 'tail')
        success, (fingerprint, hashed) = disk.get_fingerprint(self.file, length=4)
        self.assertTrue(success)
        self.assertEqual(hashed, 4)
        # Appending must not change a fingerprint taken over the same length.
        disk.write_file(self.file, 'more', append=True)
        self.assertEqual(
            disk.get_fingerprint(self.file, length=4),
            (True, (fingerprint, 4)),
        )

    def test_get_fingerprint_differs_on_rewritten_content(self):
        disk.write_file(self.file, 'before')
        success, (before, _) = disk.get_fingerprint(self.file)
        self.assertTrue(success)
        # Same length, different content: only the hash tells them apart.
        disk.write_file(self.file, 'beforf')
        success, (after, _) = disk.get_fingerprint(self.file)
        self.assertTrue(success)
        self.assertNotEqual(before, after)

    def test_get_fingerprint_tail_ignores_the_head(self):
        disk.write_file(self.file, 'head' + 'tail')
        success, (fingerprint, hashed) = disk.get_fingerprint(self.file, length=-4)
        self.assertTrue(success)
        self.assertEqual(hashed, 4)
        # Rewriting the head leaves the tail fingerprint alone ...
        disk.write_file(self.file, 'HEAD' + 'tail')
        self.assertEqual(
            disk.get_fingerprint(self.file, length=-4),
            (True, (fingerprint, 4)),
        )
        # ... while appending changes it.
        disk.write_file(self.file, 'more', append=True)
        self.assertNotEqual(
            disk.get_fingerprint(self.file, length=-4)[1][0], fingerprint
        )

    def test_get_fingerprint_head_and_tail_differ(self):
        disk.write_file(self.file, 'head' + 'tail')
        self.assertNotEqual(
            disk.get_fingerprint(self.file, length=4)[1][0],
            disk.get_fingerprint(self.file, length=-4)[1][0],
        )

    def test_get_fingerprint_whole_file_covers_a_change_in_the_middle(self):
        # Neither head nor tail sees this change, only the whole-file mode does.
        disk.write_file(self.file, 'head' + 'middle' + 'tail')
        success, (whole_before, hashed) = disk.get_fingerprint(self.file, length=0)
        self.assertTrue(success)
        self.assertEqual(hashed, 14)
        head_before = disk.get_fingerprint(self.file, length=4)
        tail_before = disk.get_fingerprint(self.file, length=-4)
        disk.write_file(self.file, 'head' + 'MIDDLE' + 'tail')
        self.assertEqual(disk.get_fingerprint(self.file, length=4), head_before)
        self.assertEqual(disk.get_fingerprint(self.file, length=-4), tail_before)
        self.assertNotEqual(
            disk.get_fingerprint(self.file, length=0)[1][0], whole_before
        )

    def test_get_fingerprint_reports_short_reads(self):
        disk.write_file(self.file, 'abc')
        self.assertEqual(disk.get_fingerprint(self.file, length=256)[1][1], 3)
        self.assertEqual(disk.get_fingerprint(self.file, length=-256)[1][1], 3)

    def test_get_fingerprint_of_a_short_file_is_side_independent(self):
        # A file shorter than the requested slice is hashed as a whole either way.
        disk.write_file(self.file, 'abc')
        self.assertEqual(
            disk.get_fingerprint(self.file, length=256),
            disk.get_fingerprint(self.file, length=-256),
        )
        self.assertEqual(
            disk.get_fingerprint(self.file, length=256),
            disk.get_fingerprint(self.file, length=0),
        )

    def test_get_fingerprint_of_an_empty_file_hashes_nothing(self):
        disk.write_file(self.file, '')
        for length in (256, -256, 0):
            self.assertEqual(disk.get_fingerprint(self.file, length=length)[1][1], 0)

    def test_get_fingerprint_on_missing_file_is_an_error(self):
        success, result = disk.get_fingerprint(os.path.join(self.dir, 'nope'))
        self.assertFalse(success)
        self.assertIn('I/O error', result)

    def test_grep_file_returns_first_group(self):
        disk.write_file(self.file, 'hello')
        self.assertEqual(disk.grep_file(self.file, 'he(l+)o'), (True, 'll'))

    def test_is_within_containment_and_escape(self):
        self.assertTrue(disk.is_within(os.path.join(self.dir, 'sub', 'a.log'), [self.dir]))
        self.assertTrue(disk.is_within(self.dir, [self.dir]))
        # `..` cannot climb out of the root
        self.assertFalse(disk.is_within(os.path.join(self.dir, '..', 'x'), [self.dir]))
        # a sibling sharing the name prefix must not match
        self.assertFalse(disk.is_within(self.dir + 'x', [self.dir]))
        # first matching root of several wins
        self.assertTrue(disk.is_within('/var/lib/mysql/h.err', ['/var/log', '/var/lib/mysql']))

    def test_is_within_resolves_symlink_out_of_root(self):
        # A symlink inside the root pointing outside is rejected: this is why an
        # operator must bind-mount (not symlink) an external location to include it.
        outside = tempfile.mkdtemp(prefix='lftest-disk-out-')
        try:
            link = os.path.join(self.dir, 'link')
            os.symlink(outside, link)
            self.assertFalse(disk.is_within(os.path.join(link, 'secret'), [self.dir]))
        finally:
            shutil.rmtree(outside, ignore_errors=True)

    def test_stat(self):
        disk.write_file(self.file, 'hello')
        st = disk.stat(self.file)
        self.assertEqual(st.st_size, 5)
        self.assertGreater(st.st_mtime, 0)
        self.assertIsNone(disk.stat(os.path.join(self.dir, 'nope')))

    def test_glob(self):
        disk.write_file(os.path.join(self.dir, 'a.log'), 'x')
        disk.mkdir(os.path.join(self.dir, 'sub'))
        disk.write_file(os.path.join(self.dir, 'sub', 'b.log'), 'y')
        flat = disk.glob(os.path.join(self.dir, '*.log'))
        self.assertEqual([os.path.basename(p) for p in flat], ['a.log'])
        deep = disk.glob(os.path.join(self.dir, '**', '*.log'))
        self.assertEqual([os.path.basename(p) for p in deep], ['a.log', 'b.log'])
        self.assertEqual(disk.glob(os.path.join(self.dir, 'nope*')), [])

    def test_read_env(self):
        envfile = os.path.join(self.dir, 'env')
        disk.write_file(envfile, 'FOO=bar\nBAZ=qux\n')
        self.assertEqual(disk.read_env(envfile), (True, {'FOO': 'bar', 'BAZ': 'qux'}))

    def test_rm_file(self):
        disk.write_file(self.file, 'x')
        disk.rm_file(self.file)
        self.assertFalse(disk.file_exists(self.file))

    def test_walk_directory_finds_file(self):
        disk.write_file(self.file, 'x')
        found = disk.walk_directory(self.dir)
        self.assertTrue(any('x.txt' in f for f in found))

    @unittest.skipUnless(hasattr(os, 'geteuid'), 'POSIX-only ownership')
    def test_get_owner(self):
        disk.write_file(self.file, 'x')
        self.assertEqual(disk.get_owner(self.file), os.geteuid())


class TestMkdir(unittest.TestCase):
    def setUp(self):
        self.dir = tempfile.mkdtemp(prefix='lftest-disk-mkdir-')

    def test_creates_nested(self):
        target = os.path.join(self.dir, 'a', 'b', 'c')
        self.assertEqual(disk.mkdir(target), (True, None))
        self.assertTrue(os.path.isdir(target))

    def test_idempotent_with_exist_ok(self):
        target = os.path.join(self.dir, 'sub')
        disk.mkdir(target)
        self.assertEqual(disk.mkdir(target), (True, None))

    def test_exist_ok_false_on_existing_is_error(self):
        ok, err = disk.mkdir(self.dir, exist_ok=False)
        self.assertFalse(ok)
        self.assertIsInstance(err, str)


class TestTreeOps(unittest.TestCase):
    def setUp(self):
        self.base = tempfile.mkdtemp(prefix='lftest-disk-tree-')

    def test_make_temp_dir(self):
        ok, path = disk.make_temp_dir(prefix='lftest-mtd-')
        self.assertTrue(ok)
        self.assertTrue(os.path.isdir(path))
        disk.rm_dir(path)

    def test_copy_file_copy_dir_rm_dir_roundtrip(self):
        src = os.path.join(self.base, 'src')
        os.makedirs(src)
        disk.write_file(os.path.join(src, 'a.txt'), 'x')

        dst_file = os.path.join(self.base, 'a-copy.txt')
        self.assertEqual(
            disk.copy_file(os.path.join(src, 'a.txt'), dst_file), (True, None)
        )
        self.assertTrue(os.path.isfile(dst_file))

        dst_dir = os.path.join(self.base, 'dst')
        self.assertEqual(disk.copy_dir(src, dst_dir), (True, None))
        self.assertTrue(os.path.isfile(os.path.join(dst_dir, 'a.txt')))

        self.assertEqual(disk.rm_dir(dst_dir), (True, None))
        self.assertFalse(os.path.isdir(dst_dir))

    def test_copy_dir_existing_dst_is_error(self):
        ok, err = disk.copy_dir(self.base, self.base)
        self.assertFalse(ok)
        self.assertIsInstance(err, str)

    def test_rm_dir_missing_is_error(self):
        ok, err = disk.rm_dir(os.path.join(self.base, 'does-not-exist'))
        self.assertFalse(ok)
        self.assertIsInstance(err, str)


class TestHostHelpers(unittest.TestCase):
    def test_get_tmpdir_absolute_without_trailing_slash(self):
        tmp = disk.get_tmpdir()
        self.assertTrue(os.path.isabs(tmp))
        self.assertFalse(tmp.endswith('/'))

    def test_get_cwd_returns_path(self):
        self.assertTrue(os.path.isdir(disk.get_cwd()))

    def test_get_block_devices_returns_list(self):
        self.assertIsInstance(disk.get_block_devices(), list)


class TestShortenPath(unittest.TestCase):
    def test_abbreviates_parents_keeps_basename(self):
        self.assertEqual(
            disk.shorten_path('/etc/pki/tls/certs/002c0b4f.0'),
            '/e/p/t/c/002c0b4f.0',
        )
        self.assertEqual(
            disk.shorten_path('/usr/share/icingaweb2/public/index.php'),
            '/u/s/i/p/index.php',
        )

    def test_two_segment_path(self):
        self.assertEqual(disk.shorten_path('/srv/index.php'), '/s/index.php')

    def test_top_level_file_stays(self):
        self.assertEqual(disk.shorten_path('/index.php'), '/index.php')

    def test_relative_path(self):
        self.assertEqual(disk.shorten_path('relative/path/file'), 'r/p/file')

    def test_no_slash_passthrough(self):
        self.assertEqual(disk.shorten_path('index.php'), 'index.php')
        self.assertEqual(disk.shorten_path('-'), '-')
        self.assertEqual(disk.shorten_path(''), '')

    def test_root_stays(self):
        self.assertEqual(disk.shorten_path('/'), '/')


if __name__ == '__main__':
    unittest.main()
