"""Discover and run all container-based library unit tests.

A module's unit test counts as container-based when its `run` file
imports testcontainers-python or uses one of the lib.lftest container
helpers. These tests build a podman container (or pull an upstream
image) and exercise the function against a live service. They take
minutes per module and need podman on the host.

Thin wrapper around `tools/run-unit-tests --only-container` so the two
entry points (fast tests and container tests) are clearly separated.
`tox` runs `tools/run-unit-tests --no-container` for multi-Python
coverage; use this runner for a full integration sweep.

Usage:
    tools/run-container-tests            # run all container tests
    tools/run-container-tests db_mysql   # run one module
"""

import subprocess
import sys

import _common

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026060201'


def main():
    runner = _common.TOOLS_DIR / 'run-unit-tests'
    argv = [sys.executable, str(runner), '--only-container', *sys.argv[1:]]
    result = subprocess.run(argv, check=False)
    return result.returncode


if __name__ == '__main__':
    sys.exit(main())
